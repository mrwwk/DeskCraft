{
  "id": "interactive_inkscape_interruption_001",
  "snapshot": "inkscape",
  "interactive": true,
  "scenario_type": "interruption",
  "scenario_description": "The user interrupts a poster editing task mid-execution and adds a late canvas-size constraint before final export.",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/inkscape/poster_template.svg",
            "path": "/home/user/Documents/poster_template.svg"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/usr/bin/inkscape",
          "/home/user/Documents/poster_template.svg"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "Open the poster and quickly make a first draft: set poster_title to 'INKSCAPE WORKSHOP', poster_subtitle to '2026 SPRING', and change the page background color to #0b1d3a.",
      "trigger": {
        "type": "step_count",
        "value": 3
      }
    },
    {
      "phase_id": 2,
      "instruction": "Interrupting with new requirements: before export, resize the document to 1080x1080 and change footer_text to 'Scan to Register'.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "Now export PNG to /home/user/Documents/workshop_square.png with width 1080.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "inkscape"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_interactive_inkscape_ii02",
      "check_inkscape_export_file_exists"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Documents/poster_template.svg",
        "dest": "interactive_inkscape_interruption_001.svg"
      },
      {
        "type": "vm_command_line",
        "command": "python3 -c \"import os; print('OK' if os.path.exists('/home/user/Documents/workshop_square.png') else 'MISSING')\"",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "text_checks": [
            {
              "element_id": "poster_title",
              "expected_text": "INKSCAPE WORKSHOP"
            },
            {
              "element_id": "poster_subtitle",
              "expected_text": "2026 SPRING"
            },
            {
              "element_id": "footer_text",
              "expected_text": "Scan to Register"
            }
          ],
          "fill_checks": [
            {
              "element_id": "page_bg",
              "expected_fill": "#0b1d3a"
            }
          ],
          "doc_check": {
            "expected_width": "1080",
            "expected_height": "1080"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected": "OK"
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "执行中断追加约束：中途改画布规格并收口导出"
}
