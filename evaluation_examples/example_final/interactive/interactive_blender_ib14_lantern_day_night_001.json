{
  "id": "interactive_blender_ib14_lantern_day_night_001",
  "snapshot": "blender",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "灯具详情页日夜双版本交付，并补对比拼图。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "source": "blender_interactive;source_type=product_detail_page;source_ref=<id_or_url>;evidence=day_night_variant",
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/blender/empty_scene.blend",
            "path": "/home/user/Documents/scene.blend"
          },
          {
            "local_path": "assets/blender/external/model_lantern.glb",
            "path": "/home/user/Documents/model_lantern.glb"
          },
          {
            "local_path": "assets/blender/external/hdri_kloppenheim_06_puresky_1k.exr",
            "path": "/home/user/Documents/hdri_kloppenheim_06_puresky_1k.exr"
          },
          {
            "local_path": "assets/blender/external/hdri/hdri_aerodynamics_workshop_1k.exr",
            "path": "/home/user/Documents/hdri_aerodynamics_workshop_1k.exr"
          },
          {
            "local_path": "assets/blender/check_render.py",
            "path": "/tmp/check_render.py"
          },
          {
            "local_path": "assets/blender/check_world.py",
            "path": "/tmp/check_world.py"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/snap/bin/blender",
          "/home/user/Documents/scene.blend"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "请导入 /home/user/Documents/model_lantern.glb，先做白天版 /home/user/Documents/lantern_day.png（1920x1080），使用 /home/user/Documents/hdri_kloppenheim_06_puresky_1k.exr。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "再做夜间版 /home/user/Documents/lantern_night.png（1920x1080），改用 /home/user/Documents/hdri_aerodynamics_workshop_1k.exr。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后导出对比图 /home/user/Documents/lantern_compare.png（PNG），并保存工程到 /home/user/Documents/ib14_delivery.blend。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "blender"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_blender_render_settings",
      "check_blender_world_hdri",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_include_exclude"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib14_delivery.blend --python /tmp/check_render.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib14_delivery.blend --python /tmp/check_world.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/lantern_day.png",
        "dest": "ib14_lantern_day.png"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/lantern_night.png",
        "dest": "ib14_lantern_night.png"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/lantern_compare.png",
        "dest": "ib14_lantern_compare.png"
      },
      {
        "type": "vm_command_line",
        "command": "for p in /home/user/Documents/lantern_day.png /home/user/Documents/lantern_night.png /home/user/Documents/lantern_compare.png /home/user/Documents/ib14_delivery.blend; do if [ -f \"$p\" ]; then echo \"EXISTS:$p\"; else echo \"MISSING:$p\"; fi; done",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "engine": "CYCLES",
          "resolution_x": 1920,
          "resolution_y": 1080,
          "image_format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "hdri_filename": "hdri_aerodynamics_workshop_1k.exr"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1920,
          "height": 1080,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1920,
          "height": 1080,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": [
            "EXISTS:/home/user/Documents/lantern_day.png",
            "EXISTS:/home/user/Documents/lantern_night.png",
            "EXISTS:/home/user/Documents/lantern_compare.png",
            "EXISTS:/home/user/Documents/ib14_delivery.blend"
          ],
          "exclude": [
            "MISSING:/home/user/Documents/lantern_day.png",
            "MISSING:/home/user/Documents/lantern_night.png",
            "MISSING:/home/user/Documents/lantern_compare.png",
            "MISSING:/home/user/Documents/ib14_delivery.blend"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3"
}
