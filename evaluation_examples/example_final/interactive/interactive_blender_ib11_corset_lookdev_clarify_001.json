{
  "id": "interactive_blender_ib11_corset_lookdev_clarify_001",
  "snapshot": "blender",
  "interactive": true,
  "scenario_type": "ambiguous_instruction",
  "scenario_description": "服饰材质 LookDev 需求先模糊，再通过追问澄清后交付。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "source": "blender_interactive;source_type=design_review;source_ref=<id_or_url>;evidence=clarification_required",
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/blender/empty_scene.blend",
            "path": "/home/user/Documents/scene.blend"
          },
          {
            "local_path": "assets/blender/external/model_corset.glb",
            "path": "/home/user/Documents/model_corset.glb"
          },
          {
            "local_path": "assets/blender/external/hdri/hdri_aerodynamics_workshop_1k.exr",
            "path": "/home/user/Documents/hdri_aerodynamics_workshop_1k.exr"
          },
          {
            "local_path": "assets/blender/check_render.py",
            "path": "/tmp/check_render.py"
          },
          {
            "local_path": "assets/blender/check_world.py",
            "path": "/tmp/check_world.py"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/snap/bin/blender",
          "/home/user/Documents/scene.blend"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "这个服饰效果不够高级，帮我调一下。",
      "trigger": {
        "type": "agent_asks"
      }
    },
    {
      "phase_id": 2,
      "instruction": "具体要求：导入 /home/user/Documents/model_corset.glb，整体偏冷色、有丝绸质感，使用 /home/user/Documents/hdri_aerodynamics_workshop_1k.exr，输出 /home/user/Documents/corset_lookdev.png（1600x2000）。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后保存工程到 /home/user/Documents/corset_lookdev.blend。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "blender"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_blender_render_settings",
      "check_blender_world_hdri",
      "check_blender_render_output",
      "check_include_exclude"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/corset_lookdev.blend --python /tmp/check_render.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/corset_lookdev.blend --python /tmp/check_world.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/corset_lookdev.png",
        "dest": "ib11_corset_lookdev.png"
      },
      {
        "type": "vm_command_line",
        "command": "for p in /home/user/Documents/corset_lookdev.png /home/user/Documents/corset_lookdev.blend; do if [ -f \"$p\" ]; then echo \"EXISTS:$p\"; else echo \"MISSING:$p\"; fi; done",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "engine": "CYCLES",
          "resolution_x": 1600,
          "resolution_y": 2000,
          "image_format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "hdri_filename": "hdri_aerodynamics_workshop_1k.exr"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1600,
          "height": 2000,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": [
            "EXISTS:/home/user/Documents/corset_lookdev.png",
            "EXISTS:/home/user/Documents/corset_lookdev.blend"
          ],
          "exclude": [
            "MISSING:/home/user/Documents/corset_lookdev.png",
            "MISSING:/home/user/Documents/corset_lookdev.blend"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3"
}
