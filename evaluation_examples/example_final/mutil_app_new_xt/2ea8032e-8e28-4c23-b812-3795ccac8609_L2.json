            {"key": ["author", "email"], "method": "eq", "ref": "mei.chen@example.org"},
            {"key": ["github_username"], "method": "eq", "ref": "meichen-dev"}
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": ["_config.yml.bak"],
          "exclude": []
        }
      }
    ],
    "options": [null, {"is_yaml": true}, null],
