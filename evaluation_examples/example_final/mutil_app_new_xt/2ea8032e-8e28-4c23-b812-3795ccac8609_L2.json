{
  "id": "2ea8032e-8e28-4c23-b812-3795ccac8609",
  "task_slug": "academic_site_config_migration_from_handoff",
  "difficulty": "L2",
  "snapshot": "multi_apps",
  "instruction": "The local academic site in ~/Desktop/academic_site/ needs to be handed over to a new owner. Review the public site structure at https://academicpages.github.io/ in Chrome, then read HANDOFF.txt in the project folder and update _config.yml in VS Code so the site reflects the new owner information. Before editing, create a backup named _config.yml.bak in the same folder.",
  "source": [
    "https://academicpages.github.io/",
    "https://docs.github.com/en/pages",
    "现实场景构造来源：学术主页换人维护时，常见的“参考线上示例站结构 + 读取 handoff + 更新本地 _config.yml 并备份”迁移流程"
  ],
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": "python3 - <<'PY'\nfrom pathlib import Path\nbase = Path('/home/user/Desktop/academic_site')\nbase.mkdir(parents=True, exist_ok=True)\n(base / 'HANDOFF.txt').write_text('name=Mei Chen\\nemail=mei.chen@example.org\\ngithub=meichen-dev\\n')\n(base / '_config.yml').write_text(\"\"\"name: Old Owner\nauthor:\n  name: Old Owner\n  email: old.owner@example.org\ngithub_username: old-owner\n\"\"\")\nPY",
        "shell": true
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["google-chrome", "--remote-debugging-port=1337"]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["socat", "tcp-listen:9222,fork", "tcp:localhost:1337"]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "https://academicpages.github.io/"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["code", "/home/user/Desktop/academic_site"]
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": ["chrome", "vscode", "os"],
  "evaluator": {
    "func": ["is_expected_active_tab_approximate", "check_json", "check_include_exclude"],
    "result": [
      {
        "type": "active_tab_info"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/academic_site/_config.yml",
        "dest": "_config.yml"
      },
      {
        "type": "vm_command_line",
        "command": "ls /home/user/Desktop/academic_site/",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "https://academicpages.github.io/"
        }
      },
      {
        "type": "rule",
