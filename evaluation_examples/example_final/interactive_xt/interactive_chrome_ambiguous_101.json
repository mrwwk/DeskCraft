{
  "id": "interactive_chrome_ambiguous_101",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "ambiguous_instruction",
  "scenario_description": "用户只模糊地说想把一个 Python 参考页留着以后查，期望 Agent 先追问具体要留哪一页、以什么方式保留。",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_learning_hub_101'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Learning Hub</h1><ul><li><a href=\"python_quick_ref.html\">Python Quick Ref</a></li><li><a href=\"git_cheatsheet.html\">Git Cheatsheet</a></li><li><a href=\"release_notes.html\">Release Notes</a></li></ul></body></html>', encoding='utf-8'); (d/'python_quick_ref.html').write_text('<html><body><h1>Python Quick Ref</h1><p>Useful reminders for Python syntax.</p></body></html>', encoding='utf-8'); (d/'git_cheatsheet.html').write_text('<html><body><h1>Git Cheatsheet</h1><p>Git commands summary.</p></body></html>', encoding='utf-8'); (d/'release_notes.html').write_text('<html><body><h1>Release Notes</h1><p>Recent release highlights.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_learning_hub_101/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "帮我把一个以后还会查的 Python 参考页留好。",
      "trigger": {
        "type": "agent_asks"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我是说 Python Quick Ref 那一页，把它打开后加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后就停留在那个 Python 页面上。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_learning_hub_101/python_quick_ref.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_learning_hub_101/python_quick_ref.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
