{
  "id": "interactive_chrome_ambiguous_111",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "ambiguous_instruction",
  "scenario_description": "用户想把浏览器准备成便于调试本地扩展的状态，但一开始没有说清是要做隐私设置还是加载扩展，期望 Agent 主动确认后完成扩展加载与收尾设置。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/debugHelperExtension'); d.mkdir(parents=True, exist_ok=True); (d/'manifest.json').write_text('{\n  \"manifest_version\": 3,\n  \"name\": \"Debug Helper\",\n  \"version\": \"1.0\",\n  \"background\": {\"service_worker\": \"background.js\"}\n}\n', encoding='utf-8'); (d/'background.js').write_text('console.log(\"debug helper ready\");\n', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "帮我把这个浏览器准备成方便调试本地扩展的状态。",
      "trigger": {
        "type": "agent_asks"
      }
    },
    {
      "phase_id": 2,
      "instruction": "具体来说，帮我把桌面上的 /home/user/Desktop/debugHelperExtension 作为 unpacked extension 加载进 Chrome。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "然后把 Do Not Track 打开，最后停留在扩展管理页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_in_list",
      "exact_match",
      "is_expected_active_tab_approximate"
    ],
    "conj": "and",
    "result": [
      {
        "type": "find_unpacked_extension_path"
      },
      {
        "type": "enable_do_not_track"
      },
      {
        "type": "active_url_from_accessTree",
        "goto_prefix": ""
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "expected": "/home/user/Desktop/debugHelperExtension"
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected": "true"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "chrome://extensions"
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
