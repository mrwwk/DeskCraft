{
  "id": "interactive_vscode_correction_104",
  "snapshot": "vscode",
  "interactive": true,
  "scenario_type": "correction",
  "scenario_description": "用户最开始说错了目标文件，随后纠正为应该把内容写入另一个 Markdown 文件，并保留原文件为空。",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "bash",
          "-lc",
          "rm -rf /home/user/Desktop/vscode_status_board && mkdir -p /home/user/Desktop/vscode_status_board && : > /home/user/Desktop/vscode_status_board/status.md && : > /home/user/Desktop/vscode_status_board/ideas.md"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/vscode_status_board"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "帮我在 status.md 里写一个标题 Project Status，并在下一行写 Overall: On Track。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我说错文件了，不是 status.md，应该把这些内容写到 ideas.md；status.md 保持空白就行。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "另外在 ideas.md 末尾再加一行：Next review: Friday.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "vscode"
  ],
  "evaluator": {
    "func": "exact_match",
    "result": {
      "type": "vm_command_line",
      "command": "python -c \"from pathlib import Path; s=Path('/home/user/Desktop/vscode_status_board/status.md'); i=Path('/home/user/Desktop/vscode_status_board/ideas.md'); expected='# Project Status\\nOverall: On Track\\nNext review: Friday.\\n'; ok=s.exists() and i.exists() and s.read_text(encoding='utf-8')=='' and i.read_text(encoding='utf-8')==expected; print('PASS' if ok else 'FAIL')\"",
      "shell": true
    },
    "expected": {
      "type": "rule",
      "rules": {
        "expected": "PASS\n"
      }
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
