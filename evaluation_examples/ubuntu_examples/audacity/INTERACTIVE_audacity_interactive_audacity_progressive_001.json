{
  "id": "interactive_audacity_progressive_001",
  "snapshot": "audacity",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "The user asks for a first delivery cut, then requests rework with a fade-out and a key label before final export.",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/wav/long_test.wav",
            "path": "/home/user/Documents/long_test.wav"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/usr/bin/audacity",
          "/home/user/Documents/long_test.wav"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "First trim this long recording to 10s-35s and export a listenable version.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "I just listened to it: the ending is abrupt. Please apply fade-out to the last 3 seconds and add a label 'KeyPoint' at around 12s in the project.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "Great, now re-export to /home/user/Documents/exports/revised_clip.wav and save the project as /home/user/Documents/revised_clip.aup3.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "audacity"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_interactive_audacity_ia05",
      "check_aup3_labels"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Documents/exports/revised_clip.wav",
        "dest": "revised_clip.wav"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/revised_clip.aup3",
        "dest": "revised_clip.aup3"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "expected_duration": 25.0,
          "duration_tolerance": 1.0,
          "fade_duration": 3.0,
          "num_windows": 5
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected_labels": [
            {
              "time": 12.0,
              "text": "KeyPoint"
            }
          ],
          "time_tolerance": 2.0
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "先交付后返工的迭代场景（初版剪辑→反馈→补淡出与标签）"
}
