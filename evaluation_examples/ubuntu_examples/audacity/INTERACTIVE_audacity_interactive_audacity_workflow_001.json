{
  "id": "interactive_audacity_workflow_001",
  "snapshot": "audacity",
  "interactive": true,
  "scenario_type": "multi_step_workflow",
  "scenario_description": "The user requests staged polishing: first a trimmed preview, then normalization and a fade-out final export.",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/wav/edit_test.wav",
            "path": "/home/user/Documents/edit_test.wav"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/usr/bin/audacity",
          "/home/user/Documents/edit_test.wav"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "First trim this audio to the range 2s to 8s and export a temporary preview so I can confirm.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "Looks good. Now normalize it to near -1 dB peak, apply fade-out to the last 2 seconds, and export to /home/user/Documents/exports/polished.wav.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "audacity"
  ],
  "evaluator": {
    "postconfig": [],
    "func": "check_interactive_audacity_ia02",
    "result": {
      "type": "vm_file",
      "path": "/home/user/Documents/exports/polished.wav",
      "dest": "polished.wav"
    },
    "expected": {
      "type": "rule",
      "rules": {
        "expected_duration": 6.0,
        "duration_tolerance": 0.8,
        "min_peak_db": -3.0,
        "max_peak_db": -0.1,
        "fade_duration": 2.0,
        "num_windows": 5
      }
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "分阶段交付的后期工作流（先预览裁剪，再定稿归一化与淡出）"
}
