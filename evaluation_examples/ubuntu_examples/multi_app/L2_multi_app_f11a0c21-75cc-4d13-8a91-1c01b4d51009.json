  "difficulty": "L2",
  "snapshot": "os",
  "instruction": "Local materials are available in Chrome at file:///home/user/Desktop/reference_story_cards_ref.html and file:///home/user/Desktop/reference_story_cards_brief.html. Use the reference only as a structural guide. Then use VS Code to build /home/user/Desktop/reference_story_cards from scratch. Create index.html, styles.css, app.js, and manifest.json. Build a page with section#hero, section#story-grid containing exactly 4 article.story-card blocks, aside#editor-note, and footer.site-footer. Give each story-card a heading and short supporting copy. Manifest must set project to reference-story-cards, theme to warm-editorial, version to 1.0, and previewPort to 8129. Start a local preview server and finish with Chrome open at http://127.0.0.1:8129/index.html.",
  "source": "https://www.frontendmentor.io/challenges",
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": ["/bin/bash", "-c", "rm -rf /home/user/Desktop/reference_story_cards && mkdir -p /home/user/Desktop/reference_story_cards"]
      }
    },
    {
