      "parameters": {
        "files": [
          { "local_path": "assets/ui_gen/l2_reference_story_cards/reference.html", "path": "/home/user/Desktop/reference_story_cards_ref.html" },
          { "local_path": "assets/ui_gen/l2_reference_story_cards/brief.html", "path": "/home/user/Desktop/reference_story_cards_brief.html" }
        ]
      }
    },
    { "type": "launch", "parameters": { "command": ["google-chrome", "--remote-debugging-port=1337"] } },
    { "type": "launch", "parameters": { "command": ["socat", "tcp-listen:9222,fork", "tcp:localhost:1337"] } },
    {
      "type": "chrome_open_tabs",
      "parameters": { "urls_to_open": ["file:///home/user/Desktop/reference_story_cards_ref.html", "file:///home/user/Desktop/reference_story_cards_brief.html"] }
