{
  "id": "interactive_os_correction_105",
  "snapshot": "os",
  "interactive": true,
  "scenario_type": "correction",
  "scenario_description": "用户先把两个文件都归到 Work，随后纠正其中一个文本文件应该放到 Notes，并补充图片也要归档到 Pictures。",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "bash",
          "-lc",
          "rm -f /home/user/Desktop/vacation.jpg /home/user/Desktop/budget.xlsx /home/user/Desktop/ideas.txt && touch /home/user/Desktop/vacation.jpg /home/user/Desktop/budget.xlsx /home/user/Desktop/ideas.txt && mkdir -p /home/user/Pictures /home/user/Work /home/user/Notes"
        ]
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先把 budget.xlsx 和 ideas.txt 都移到 Work 文件夹里。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我说错了，ideas.txt 不该进 Work，应该放到 Notes。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "另外把 vacation.jpg 也移到 Pictures。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "os"
  ],
  "evaluator": {
    "func": "check_include_exclude",
    "result": {
      "type": "vm_command_line",
        "command": "DESK=$(find /home/user/Desktop -maxdepth 1 -type f \\( -name 'vacation.jpg' -o -name 'budget.xlsx' -o -name 'ideas.txt' \\) -printf '%f ' | sort); PIC=$(ls /home/user/Pictures 2>/dev/null | sort | tr '\\n' ' '); WORK=$(ls /home/user/Work 2>/dev/null | sort | tr '\\n' ' '); NOTES=$(ls /home/user/Notes 2>/dev/null | sort | tr '\\n' ' '); echo DESK:$DESK PIC:$PIC WORK:$WORK NOTES:$NOTES",
      "shell": true
    },
    "expected": {
      "type": "rule",
      "rules": {
        "include": [
          "PIC:vacation.jpg",
          "WORK:budget.xlsx",
          "NOTES:ideas.txt"
        ],
        "exclude": [
          "DESK:vacation.jpg",
          "DESK:budget.xlsx",
          "DESK:ideas.txt",
          "WORK:ideas.txt",
          "NOTES:budget.xlsx",
          "PIC:budget.xlsx"
        ]
      }
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
