{
  "id": "interactive_vscode_correction_109",
  "snapshot": "vscode",
  "interactive": true,
  "scenario_type": "correction",
  "scenario_description": "用户想把当前工作区调成适合 code review 的编辑环境，但中途纠正了 tab size 和 ruler 的要求，最终要求写入工作区设置。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "bash",
          "-lc",
          "rm -rf /home/user/Desktop/vscode_focus_review_109 && mkdir -p /home/user/Desktop/vscode_focus_review_109/.vscode && printf '{}\n' > /home/user/Desktop/vscode_focus_review_109/.vscode/settings.json"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/vscode_focus_review_109"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "帮我把这个工作区调成适合 code review：先把 tab size 设成 2，打开 trim trailing whitespace，并加一条 80 列的 ruler。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我刚说错了，tab size 不是 2，要改成 4，而且 ruler 也改成 100。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "另外再打开 format on save 和 insert final newline。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "vscode"
  ],
  "evaluator": {
    "func": "check_json_settings",
    "expected": {
      "type": "rule",
      "rules": {
        "expected": {
          "editor.tabSize": 4,
          "files.trimTrailingWhitespace": true,
          "editor.rulers": [
            100
          ],
          "editor.formatOnSave": true,
          "files.insertFinalNewline": true
        }
      }
    },
    "result": {
      "type": "vm_file",
      "path": "/home/user/Desktop/vscode_focus_review_109/.vscode/settings.json",
      "dest": "workspace_settings.json"
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
