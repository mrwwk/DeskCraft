{
  "id": "interactive_inkscape_workflow_001",
  "snapshot": "inkscape",
  "interactive": true,
  "scenario_type": "multi_step_workflow",
  "scenario_description": "The user provides a staged layer-handoff workflow and checks each milestone before final export.",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/inkscape/three_layers.svg",
            "path": "/home/user/Documents/three_layers.svg"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/usr/bin/inkscape",
          "/home/user/Documents/three_layers.svg"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "First reorganize layer order to Background, Labels, Shapes.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "Now rename the Shapes layer (id=layer2) to Main Content.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "Hide the Labels layer and change bg_rect fill to #fffde7.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 4,
      "instruction": "Final step: export PNG to /home/user/Documents/layer_handoff.png with width 1600.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "inkscape"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_interactive_inkscape_ii06",
      "check_inkscape_export_file_exists"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Documents/three_layers.svg",
        "dest": "interactive_inkscape_workflow_001.svg"
      },
      {
        "type": "vm_command_line",
        "command": "python3 -c \"import os; print('OK' if os.path.exists('/home/user/Documents/layer_handoff.png') else 'MISSING')\"",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "layer_order_check": {
            "expected_order": [
              "Background",
              "Labels",
              "Main Content"
            ]
          },
          "layer_name_check": {
            "layer_id": "layer2",
            "expected_label": "Main Content"
          },
          "visibility_check": {
            "layer_label": "Labels",
            "expected_visible": false
          },
          "fill_check": {
            "element_id": "bg_rect",
            "expected_fill": "#fffde7"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected": "OK"
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "多阶段交接：按图层规范逐步验收并导出"
}
