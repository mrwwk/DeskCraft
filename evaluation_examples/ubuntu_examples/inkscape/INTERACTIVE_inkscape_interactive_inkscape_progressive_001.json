{
  "id": "interactive_inkscape_progressive_001",
  "snapshot": "inkscape",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "The user asks for an initial icon draft, then progressively refines colors and text before final export.",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/inkscape/icon_parts.svg",
            "path": "/home/user/Documents/icon_parts.svg"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/usr/bin/inkscape",
          "/home/user/Documents/icon_parts.svg"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "First give me a quick icon draft by arranging the parts into a centered composition.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "Looks okay, now refine colors: set icon_bg to #2c3e50, icon_triangle to #ffffff, and accent_dot to #f39c12.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "Final change: set icon_label text to 'PlayApp', then export PNG to /home/user/Documents/playapp_icon.png with width 1024.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "inkscape"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_interactive_inkscape_ii03",
      "check_inkscape_export_file_exists"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Documents/icon_parts.svg",
        "dest": "interactive_inkscape_progressive_001.svg"
      },
      {
        "type": "vm_command_line",
        "command": "python3 -c \"import os; print('OK' if os.path.exists('/home/user/Documents/playapp_icon.png') else 'MISSING')\"",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "fill_checks": [
            {
              "element_id": "icon_bg",
              "expected_fill": "#2c3e50"
            },
            {
              "element_id": "icon_triangle",
              "expected_fill": "#ffffff"
            },
            {
              "element_id": "accent_dot",
              "expected_fill": "#f39c12"
            }
          ],
          "text_check": {
            "element_id": "icon_label",
            "expected_text": "PlayApp"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected": "OK"
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "渐进细化：先初稿后反馈调色与文案再导出"
}
