{
  "id": "interactive_blender_ib07_bottle_multidelivery_001",
  "snapshot": "blender",
  "interactive": true,
  "scenario_type": "multi_step_workflow",
  "scenario_description": "电商饮品图分阶段交付：预览图 -> 正式方图 -> 透明底抠图。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "source": "blender_interactive;source_type=ecommerce_pipeline;source_ref=<id_or_url>;evidence=multi_output_delivery",
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/blend/empty_scene.blend",
            "path": "/home/user/Documents/scene.blend"
          },
          {
            "local_path": "assets/glb/model_waterbottle.glb",
            "path": "/home/user/Documents/model_waterbottle.glb"
          },
          {
            "local_path": "assets/exr/hdri_kloppenheim_06_puresky_1k.exr",
            "path": "/home/user/Documents/hdri_kloppenheim_06_puresky_1k.exr"
          },
          {
            "local_path": "assets/py/check_render.py",
            "path": "/tmp/check_render.py"
          },
          {
            "local_path": "assets/py/check_world.py",
            "path": "/tmp/check_world.py"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/snap/bin/blender",
          "/home/user/Documents/scene.blend"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "请先导入 /home/user/Documents/model_waterbottle.glb，用 /home/user/Documents/hdri_kloppenheim_06_puresky_1k.exr 做自然光，先出预览图 /home/user/Documents/bottle_preview.jpg（JPG）。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "构图没问题，改成 2000x2000 的正式图，导出 /home/user/Documents/bottle_final.png。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "再导一张透明背景版本 /home/user/Documents/bottle_cutout.png，并把工程保存为 /home/user/Documents/ib07_delivery.blend。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "blender"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_blender_render_settings",
      "check_blender_world_hdri",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_include_exclude"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib07_delivery.blend --python /tmp/check_render.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib07_delivery.blend --python /tmp/check_world.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/bottle_preview.jpg",
        "dest": "ib07_bottle_preview.jpg"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/bottle_final.png",
        "dest": "ib07_bottle_final.png"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/bottle_cutout.png",
        "dest": "ib07_bottle_cutout.png"
      },
      {
        "type": "vm_command_line",
        "command": "for p in /home/user/Documents/bottle_preview.jpg /home/user/Documents/bottle_final.png /home/user/Documents/bottle_cutout.png /home/user/Documents/ib07_delivery.blend; do if [ -f \"$p\" ]; then echo \"EXISTS:$p\"; else echo \"MISSING:$p\"; fi; done",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "engine": "CYCLES",
          "resolution_x": 2000,
          "resolution_y": 2000,
          "image_format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "hdri_filename": "hdri_kloppenheim_06_puresky_1k.exr"
        }
      },
      {
        "type": "rule",
        "rules": {
          "format": "JPEG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 2000,
          "height": 2000,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": [
            "EXISTS:/home/user/Documents/bottle_preview.jpg",
            "EXISTS:/home/user/Documents/bottle_final.png",
            "EXISTS:/home/user/Documents/bottle_cutout.png",
            "EXISTS:/home/user/Documents/ib07_delivery.blend"
          ],
          "exclude": [
            "MISSING:/home/user/Documents/bottle_preview.jpg",
            "MISSING:/home/user/Documents/bottle_final.png",
            "MISSING:/home/user/Documents/bottle_cutout.png",
            "MISSING:/home/user/Documents/ib07_delivery.blend"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3"
}
