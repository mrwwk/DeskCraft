{
  "id": "interactive_blender_ib10_boombox_compliance_rework_001",
  "snapshot": "blender",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "消费电子主视觉图法务返工：v1 -> 安全区版 v2 -> 缩略图。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "source": "blender_interactive;source_type=compliance_rework;source_ref=<id_or_url>;evidence=safe_area_adjustment",
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/blender/empty_scene.blend",
            "path": "/home/user/Documents/scene.blend"
          },
          {
            "local_path": "assets/blender/external/model_boombox.glb",
            "path": "/home/user/Documents/model_boombox.glb"
          },
          {
            "local_path": "assets/blender/check_render.py",
            "path": "/tmp/check_render.py"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/snap/bin/blender",
          "/home/user/Documents/scene.blend"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先导入 /home/user/Documents/model_boombox.glb，输出主视觉 v1：/home/user/Documents/boombox_hero_v1.png（1920x1080）。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "法务反馈：右上角留安全区，重渲 /home/user/Documents/boombox_hero_v2.png（1920x1080）。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "再导出缩略图 /home/user/Documents/boombox_thumb.png（1080x1080），并保存工程到 /home/user/Documents/ib10_delivery.blend。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "blender"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_blender_render_settings",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_include_exclude"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib10_delivery.blend --python /tmp/check_render.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/boombox_hero_v1.png",
        "dest": "ib10_boombox_hero_v1.png"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/boombox_hero_v2.png",
        "dest": "ib10_boombox_hero_v2.png"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/boombox_thumb.png",
        "dest": "ib10_boombox_thumb.png"
      },
      {
        "type": "vm_command_line",
        "command": "for p in /home/user/Documents/boombox_hero_v1.png /home/user/Documents/boombox_hero_v2.png /home/user/Documents/boombox_thumb.png /home/user/Documents/ib10_delivery.blend; do if [ -f \"$p\" ]; then echo \"EXISTS:$p\"; else echo \"MISSING:$p\"; fi; done",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "engine": "CYCLES",
          "resolution_x": 1080,
          "resolution_y": 1080,
          "image_format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1920,
          "height": 1080,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1920,
          "height": 1080,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1080,
          "height": 1080,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": [
            "EXISTS:/home/user/Documents/boombox_hero_v1.png",
            "EXISTS:/home/user/Documents/boombox_hero_v2.png",
            "EXISTS:/home/user/Documents/boombox_thumb.png",
            "EXISTS:/home/user/Documents/ib10_delivery.blend"
          ],
          "exclude": [
            "MISSING:/home/user/Documents/boombox_hero_v1.png",
            "MISSING:/home/user/Documents/boombox_hero_v2.png",
            "MISSING:/home/user/Documents/boombox_thumb.png",
            "MISSING:/home/user/Documents/ib10_delivery.blend"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3"
}
