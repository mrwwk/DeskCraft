{
  "id": "interactive_blender_ib08_avocado_lighting_ab_001",
  "snapshot": "blender",
  "interactive": true,
  "scenario_type": "requirement_change",
  "scenario_description": "食品广告 A/B 光照对比：先自然光 A 版，再中途切换棚感光做 B 版。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "source": "blender_interactive;source_type=marketing_change_request;source_ref=<id_or_url>;evidence=lighting_style_switch",
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/blender/empty_scene.blend",
            "path": "/home/user/Documents/scene.blend"
          },
          {
            "local_path": "assets/blender/external/model_avocado.glb",
            "path": "/home/user/Documents/model_avocado.glb"
          },
          {
            "local_path": "assets/blender/external/hdri_kloppenheim_06_puresky_1k.exr",
            "path": "/home/user/Documents/hdri_kloppenheim_06_puresky_1k.exr"
          },
          {
            "local_path": "assets/blender/external/hdri/hdri_aerodynamics_workshop_1k.exr",
            "path": "/home/user/Documents/hdri_aerodynamics_workshop_1k.exr"
          },
          {
            "local_path": "assets/blender/check_render.py",
            "path": "/tmp/check_render.py"
          },
          {
            "local_path": "assets/blender/check_world.py",
            "path": "/tmp/check_world.py"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/snap/bin/blender",
          "/home/user/Documents/scene.blend"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先导入 /home/user/Documents/model_avocado.glb，用 /home/user/Documents/hdri_kloppenheim_06_puresky_1k.exr 做 A 版，渲染 /home/user/Documents/avocado_a.png（1600x1600）。",
      "trigger": {
        "type": "step_count",
        "value": 4
      }
    },
    {
      "phase_id": 2,
      "instruction": "中途改需求：把光照改成 /home/user/Documents/hdri_aerodynamics_workshop_1k.exr，做 B 版 /home/user/Documents/avocado_b.png（1600x1600），并保存 /home/user/Documents/ib08_delivery.blend。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "blender"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_blender_render_settings",
      "check_blender_world_hdri",
      "check_blender_render_output",
      "check_blender_render_output",
      "check_include_exclude"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib08_delivery.blend --python /tmp/check_render.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_command_line",
        "command": "/snap/bin/blender --background /home/user/Documents/ib08_delivery.blend --python /tmp/check_world.py 2>&1 | grep '^RESULT:' | sed 's/^RESULT://'",
        "shell": true
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/avocado_a.png",
        "dest": "ib08_avocado_a.png"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Documents/avocado_b.png",
        "dest": "ib08_avocado_b.png"
      },
      {
        "type": "vm_command_line",
        "command": "for p in /home/user/Documents/avocado_a.png /home/user/Documents/avocado_b.png /home/user/Documents/ib08_delivery.blend; do if [ -f \"$p\" ]; then echo \"EXISTS:$p\"; else echo \"MISSING:$p\"; fi; done",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "engine": "CYCLES",
          "resolution_x": 1600,
          "resolution_y": 1600,
          "image_format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "hdri_filename": "hdri_aerodynamics_workshop_1k.exr"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1600,
          "height": 1600,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "width": 1600,
          "height": 1600,
          "format": "PNG"
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": [
            "EXISTS:/home/user/Documents/avocado_a.png",
            "EXISTS:/home/user/Documents/avocado_b.png",
            "EXISTS:/home/user/Documents/ib08_delivery.blend"
          ],
          "exclude": [
            "MISSING:/home/user/Documents/avocado_a.png",
            "MISSING:/home/user/Documents/avocado_b.png",
            "MISSING:/home/user/Documents/ib08_delivery.blend"
          ]
        }
      }
    ]
  },
  "proxy": false,
