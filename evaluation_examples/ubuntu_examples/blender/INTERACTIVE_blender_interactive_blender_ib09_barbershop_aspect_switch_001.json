          },
          {
            "local_path": "assets/jpg/BarberShopChair_01_diff_1k.jpg",
            "path": "/home/user/Documents/textures/BarberShopChair_01_diff_1k.jpg"
          },
          {
            "local_path": "assets/jpg/BarberShopChair_01_nor_gl_1k.jpg",
            "path": "/home/user/Documents/textures/BarberShopChair_01_nor_gl_1k.jpg"
          },
          {
            "local_path": "assets/jpg/BarberShopChair_01_arm_1k.jpg",
            "path": "/home/user/Documents/textures/BarberShopChair_01_arm_1k.jpg"
          },
          {
            "local_path": "assets/py/check_render.py",
            "path": "/tmp/check_render.py"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/snap/bin/blender",
          "/home/user/Documents/scene.blend"
        ]
      }
