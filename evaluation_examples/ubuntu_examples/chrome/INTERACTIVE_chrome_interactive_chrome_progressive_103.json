{
  "id": "interactive_chrome_progressive_103",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "用户先要求打开一个快捷参考页，随后逐步补充要加入书签栏的第二个页面，并要求最终停留在第二个页面。",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_dev_docs_103'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Dev Docs</h1><ul><li><a href=\"keyboard_shortcuts.html\">Keyboard Shortcuts</a></li><li><a href=\"extensions_guide.html\">Extensions Guide</a></li></ul></body></html>', encoding='utf-8'); (d/'keyboard_shortcuts.html').write_text('<html><body><h1>Keyboard Shortcuts</h1><p>Useful keyboard shortcuts.</p></body></html>', encoding='utf-8'); (d/'extensions_guide.html').write_text('<html><body><h1>Extensions Guide</h1><p>How to manage extensions.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_dev_docs_103/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先打开 Keyboard Shortcuts 这一页。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "把 Keyboard Shortcuts 加到书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "再把 Extensions Guide 也打开并加入书签栏，最后停留在 Extensions Guide 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_dev_docs_103/extensions_guide.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_dev_docs_103/keyboard_shortcuts.html",
            "file:///home/user/Desktop/chrome_dev_docs_103/extensions_guide.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
