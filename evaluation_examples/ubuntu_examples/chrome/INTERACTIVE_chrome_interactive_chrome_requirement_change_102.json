{
  "id": "interactive_chrome_requirement_change_102",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "requirement_change",
  "scenario_description": "用户先让 Agent 保留一个部署清单页面，随后改口说真正要保留的是故障应急手册页面，并要求撤销前一个目标，只保留最终手册页。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_ops_hub_102'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Operations Hub</h1><ul><li><a href=\"deployment_checklist.html\">Deployment Checklist</a></li><li><a href=\"incident_runbook.html\">Incident Runbook</a></li></ul></body></html>', encoding='utf-8'); (d/'deployment_checklist.html').write_text('<html><body><h1>Deployment Checklist</h1><p>Checklist before release.</p></body></html>', encoding='utf-8'); (d/'incident_runbook.html').write_text('<html><body><h1>Incident Runbook</h1><p>Emergency response steps.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_ops_hub_102/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "打开 Deployment Checklist 那一页，并把它加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "等一下，不是这个，真正要保留的是 Incident Runbook；把书签栏里保留它，不要刚才那个。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后浏览器里只保留 Incident Runbook 这一个文档标签，并停留在那一页。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_tabs",
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "open_tabs_info"
      },
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "urls": [
            "file:///home/user/Desktop/chrome_ops_hub_102/incident_runbook.html"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_ops_hub_102/incident_runbook.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_ops_hub_102/incident_runbook.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
