{
  "id": "interactive_chrome_requirement_change_206",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "requirement_change",
  "scenario_description": "用户先让 Agent 保留一组偏营销展示的参考页，但随后改口，要求只留下 dashboard 和 modal 交互相关的 UI 参考，并清理旧书签。",
  "source": "https://www.frontendmentor.io/challenges/bento-grid-RMydElrlOj | https://www.frontendmentor.io/challenges/time-tracking-dashboard-UIQ7167Jw | https://developer.mozilla.org/en-US/docs/Web/HTML/Element/dialog | authors",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/ui_reference_lab_206'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>UI Reference Lab</h1><ul><li><a href=\"dashboard_signals.html\">Dashboard Signals</a></li><li><a href=\"bento_story.html\">Bento Story</a></li><li><a href=\"modal_handoff.html\">Modal Handoff</a></li><li><a href=\"form_rules.html\">Form Rules</a></li></ul></body></html>', encoding='utf-8'); (d/'dashboard_signals.html').write_text('<html><body><h1>Dashboard Signals</h1></body></html>', encoding='utf-8'); (d/'bento_story.html').write_text('<html><body><h1>Bento Story</h1></body></html>', encoding='utf-8'); (d/'modal_handoff.html').write_text('<html><body><h1>Modal Handoff</h1></body></html>', encoding='utf-8'); (d/'form_rules.html').write_text('<html><body><h1>Form Rules</h1></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/ui_reference_lab_206/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先打开 Bento Story 和 Form Rules 这两个参考页，并把它们都加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我改主意了，不再保留 Bento Story 和 Form Rules。改成打开 Dashboard Signals 和 Modal Handoff，并把书签栏改成只保留这两个页面。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后把首页标签和其它无关标签都关掉，只保留 Dashboard Signals 与 Modal Handoff 两个参考页，并停留在 Modal Handoff。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_tabs",
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "open_tabs_info"
      },
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "urls": [
            "file:///home/user/Desktop/ui_reference_lab_206/dashboard_signals.html",
            "file:///home/user/Desktop/ui_reference_lab_206/modal_handoff.html"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/ui_reference_lab_206/modal_handoff.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/ui_reference_lab_206/dashboard_signals.html",
            "file:///home/user/Desktop/ui_reference_lab_206/modal_handoff.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
