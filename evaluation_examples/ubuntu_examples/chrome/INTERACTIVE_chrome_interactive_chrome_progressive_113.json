{
  "id": "interactive_chrome_progressive_113",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "用户在一个本地运维知识库里逐步补充自己值班时常用的参考页，要求 Agent 连续开页、整理标签并挑选真正需要留在书签栏里的页面。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_ops_hub_113'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Ops Hub</h1><ul><li><a href=\"incident_response.html\">Incident Response</a></li><li><a href=\"rollback_checklist.html\">Rollback Checklist</a></li><li><a href=\"status_page_guide.html\">Status Page Guide</a></li></ul></body></html>', encoding='utf-8'); (d/'incident_response.html').write_text('<html><body><h1>Incident Response</h1></body></html>', encoding='utf-8'); (d/'rollback_checklist.html').write_text('<html><body><h1>Rollback Checklist</h1></body></html>', encoding='utf-8'); (d/'status_page_guide.html').write_text('<html><body><h1>Status Page Guide</h1></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_ops_hub_113/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先把 Incident Response 打开成单独标签页。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "再把 Rollback Checklist 也打开成单独标签页。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后把 Status Page Guide 也打开成单独标签页，只保留这三个文档标签，不要留首页标签；然后把 Incident Response 和 Status Page Guide 加进书签栏，并停留在 Status Page Guide 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_tabs",
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "open_tabs_info"
      },
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "urls": [
            "file:///home/user/Desktop/chrome_ops_hub_113/incident_response.html",
            "file:///home/user/Desktop/chrome_ops_hub_113/rollback_checklist.html",
            "file:///home/user/Desktop/chrome_ops_hub_113/status_page_guide.html"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_ops_hub_113/status_page_guide.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_ops_hub_113/incident_response.html",
            "file:///home/user/Desktop/chrome_ops_hub_113/status_page_guide.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
