{
  "id": "interactive_chrome_ambiguous_106",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "ambiguous_instruction",
  "scenario_description": "用户在一个本地供应商门户里只模糊地说想把后续常用页面留好，期望 Agent 先确认是要保留哪些页面，再用书签栏组织起来。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_vendor_portal_106'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Vendor Portal</h1><ul><li><a href=\"shipping_policy.html\">Shipping Policy</a></li><li><a href=\"returns.html\">Returns</a></li><li><a href=\"vendor_contacts.html\">Vendor Contacts</a></li></ul></body></html>', encoding='utf-8'); (d/'shipping_policy.html').write_text('<html><body><h1>Shipping Policy</h1><p>Carrier cut-off is 5 PM.</p></body></html>', encoding='utf-8'); (d/'returns.html').write_text('<html><body><h1>Returns</h1><p>Returns require approval within 14 days.</p></body></html>', encoding='utf-8'); (d/'vendor_contacts.html').write_text('<html><body><h1>Vendor Contacts</h1><p>Escalation owner: Maya.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_vendor_portal_106/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "这个供应商门户里有几页我后面会经常看，但我现在说不清，你先问我一下要怎么留。",
      "trigger": {
        "type": "agent_asks"
      }
    },
    {
      "phase_id": 2,
      "instruction": "把 Shipping Policy 和 Returns 这两页都打开并加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后停留在 Returns 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_vendor_portal_106/returns.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_vendor_portal_106/shipping_policy.html",
            "file:///home/user/Desktop/chrome_vendor_portal_106/returns.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
