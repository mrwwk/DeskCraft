{
  "id": "interactive_kdenlive_requirement_change_001",
  "snapshot": "kdenlive",
  "interactive": true,
  "scenario_type": "requirement_change",
  "scenario_description": "During a midday ad-review meeting, the user changes an in-progress horizontal teaser into a vertical short-feed deliverable and asks for same-day output.",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/mp4/15368811_1920_1080_30fps.mp4",
            "path": "/home/user/Videos/15368811_1920_1080_30fps.mp4"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/home/user/.local/bin/kdenlive"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "Start a horizontal teaser draft: import /home/user/Videos/15368811_1920_1080_30fps.mp4, place it on V1, and prepare a quick first version with a short title card 'New Product Teaser'.",
      "trigger": {
        "type": "step_count",
        "value": 3
      }
    },
    {
      "phase_id": 2,
      "instruction": "New requirement from the media team: switch to a 1080x1920 vertical project, render as MP4 (H.264) to /home/user/Videos/teaser_vertical.mp4, and save the project as /home/user/Videos/teaser_vertical.kdenlive.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "kdenlive"
  ],
  "evaluator": {
    "postconfig": [],
    "func": [
      "check_kdenlive_render_custom_resolution",
      "check_kdenlive_file_exists"
    ],
    "conj": "and",
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Videos/teaser_vertical.mp4",
        "dest": "teaser_vertical.mp4"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Videos/teaser_vertical.kdenlive",
        "dest": "teaser_vertical.kdenlive"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "min_duration": 1.0,
          "expected_codec": "h264",
          "expected_width": 1080,
          "expected_height": 1920
        }
      },
      {
        "type": "rule",
        "rules": {
          "valid_xml": true
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "kdenlive_interactive;source_type=marketing_change_request;source_ref=<id_or_url>;evidence=aspect_ratio_pivot"
}
