{
  "id": "interactive_kdenlive_progressive_001",
  "snapshot": "kdenlive",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "Client review happens in rounds: deliver a structure-only v1 first, then add color grading and audio finishing before final export.",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "upload_file",
      "parameters": {
        "files": [
          {
            "local_path": "assets/mp4/6533277-hd_1920_1080_24fps.mp4",
            "path": "/home/user/Videos/6533277-hd_1920_1080_24fps.mp4"
          }
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "/home/user/.local/bin/kdenlive"
        ]
      }
    },
    {
      "type": "sleep",
      "parameters": {
        "seconds": 3
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "Create a v1 structural draft using roughly the first 12 seconds of /home/user/Videos/6533277-hd_1920_1080_24fps.mp4 and save it as /home/user/Videos/color_v1.kdenlive.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "Second-round feedback: apply Brightness and Sepia effects in this order, then save the updated project as /home/user/Videos/color_final.kdenlive.",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "Final polish: add 2-second audio fade-in and 2-second audio fade-out, then render to /home/user/Videos/color_final.mp4.",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "kdenlive"
  ],
  "evaluator": {
    "postconfig": [],
    "func": "check_kdenlive_render_color_grading",
    "result": {
      "type": "vm_file",
      "path": [
        "/home/user/Videos/color_final.mp4",
        "/home/user/Videos/color_final.kdenlive"
      ],
      "dest": [
        "color_final.mp4",
        "color_final.kdenlive"
      ],
      "multi": true
    },
    "expected": {
      "type": "rule",
      "rules": {
        "min_duration": 1.0,
        "expected_codec": "h264",
        "require_brightness": true,
        "require_sepia": true,
        "require_fade_in": true,
        "require_fade_out": true
      }
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3",
  "source": "kdenlive_interactive;source_type=iterative_delivery;source_ref=<id_or_url>;evidence=rework_loop"
}
