{
    "id": "interactive_calc_019",
    "snapshot": "libreoffice_calc",
    "interactive": true,
    "scenario_type": "requirement_change",
    "scenario_description": "用户先让在Sheet2统计各Invoice No.出现次数，然后改为统计金额总和。",
    "user_persona": {
        "expertise_level": "intermediate",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "download",
            "parameters": {
                "files": [
                    {
                        "url": "https://huggingface.co/datasets/xlangai/ubuntu_osworld_file_cache/resolve/main/libreoffice_calc/1954cced-e748-45c4-9c26-9855b97fbc5e/Invoices.xlsx",
                        "path": "/home/user/Desktop/Invoices.xlsx"
                    }
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--calc",
                    "/home/user/Desktop/Invoices.xlsx"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我在Sheet2里统计每个Invoice No.出现次数",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "不统计次数了，改成统计每个Invoice No.对应的金额总和，列名改成'Total Amount'，保存",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_calc"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "python3 -c \"import pandas as pd; xl = pd.ExcelFile('/home/user/Desktop/Invoices.xlsx'); ok = 'Sheet2' in xl.sheet_names; df2 = pd.read_excel('/home/user/Desktop/Invoices.xlsx', sheet_name='Sheet2') if ok else None; has_col = ok and df2 is not None and any('total amount' in str(c).lower() for c in df2.columns); print('PASSED' if has_col else 'FAILED')\""
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "PASSED"
                ],
                "exclude": [
                    "FAILED"
                ]
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}