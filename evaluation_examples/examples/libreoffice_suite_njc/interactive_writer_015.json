{
    "id": "interactive_writer_015",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "progressive_refinement",
    "scenario_description": "用户先提供产品名称让Agent填入规格书，再补充产品编号。",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "printf '产品规格书\n\n产品名称：\n产品编号：\n版本号：V1.0\n编制日期：2025年6月25日\n\n一、产品概述\n本产品是一款面向家庭用户的智能家居控制设备。\n\n二、技术规格\n工作电压：220V AC\n功耗：≤15W\n工作温度：-10°C至50°C\n通信协议：Wi-Fi 802.11 b/g/n\n\n三、包装清单\n主机 × 1\n电源适配器 × 1\n说明书 × 1\n' > /home/user/Desktop/product_spec.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--writer",
                    "/home/user/Desktop/product_spec.txt"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我把产品名称填上：智能温控器Pro",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "在文档的最末尾另起一行，加上\"产品编号：TC-2025-001\"，然后保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "cat /home/user/Desktop/product_spec.txt"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "TC-2025-001"
                ],
                "exclude": []
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}