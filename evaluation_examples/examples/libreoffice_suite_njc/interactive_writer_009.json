{
    "id": "interactive_writer_009",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "ambiguous_scope",
    "scenario_description": "公告里有多个日期，用户说更新日期但没指明哪一个。Agent 询问后只改发布日期。",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "printf '关于系统维护的通知\n\n发布日期：2025年3月15日\n\n各位员工：\n\nIT部门将于近期开展系统例行维护，具体安排如下：\n\n维护时间：2025年4月2日 22:00至次日2:00\n影响范围：ERP系统、OA系统、邮件系统\n\n注意事项：\n1. 请在2025年4月2日20:00前保存重要数据。\n2. 维护期间紧急事务请联系IT值班：021-99887766。\n3. 系统预计于2025年4月3日2:30恢复正常。\n\nIT运营部  2025年3月15日\n' > /home/user/Desktop/announcement.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--writer",
                    "/home/user/Desktop/announcement.txt"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我更新一下文件里的日期",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "在文档的最末尾另起一行，加上\"更新说明：发布日期已更新为2025年7月1日\"，然后保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "cat /home/user/Desktop/announcement.txt"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "2025年7月1日"
                ],
                "exclude": []
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}