{
    "id": "interactive_writer_013",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "progressive_refinement",
    "scenario_description": "用户先让Agent在请假邮件里写好基本框架，再补充请假原因和天数。",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "printf '收件人：人事部\n抄送：直属上级 张总\n主题：请假申请\n\n尊敬的人事部：\n您好！\n\n我是技术部员工，工号：T2025-089。\n现申请请假，相关信息如下：\n\n请假类型：\n请假原因：\n请假时间：\n请假天数：\n\n请审批，谢谢！\n\n此致\n申请人：林小雨\n2025年6月20日\n' > /home/user/Desktop/leave_email.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--writer",
                    "/home/user/Desktop/leave_email.txt"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我在请假邮件里把基本信息写上",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "在文档的最末尾另起一行，加上\"请假原因：身体不适，请假天数：3天\"，然后保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer"
    ],
    "evaluator": {
        "func": "check_include_exclude",
