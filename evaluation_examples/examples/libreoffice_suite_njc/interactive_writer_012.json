{
    "id": "interactive_writer_012",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "ambiguous_scope",
    "scenario_description": "会议纪要包含多个议题，用户要加决议但未说是哪个议题。Agent 询问后只加在第一个议题下。",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "printf '项目周会纪要\n\n时间：2025年6月17日 10:00-11:30\n地点：A栋315会议室\n主持人：项目经理 李强\n\n议题一：前端开发进度汇报\n  汇报人：张敏\n  内容：目前完成约70%%，预计下周五完成全部功能开发。\n\n议题二：测试环境搭建\n  汇报人：赵辉\n  内容：测试环境已搭建完毕，等待前端代码后启动测试。\n\n议题三：发布上线计划\n  汇报人：李强\n  内容：计划8月1日正式上线，期间安排两轮内部测试。\n' > /home/user/Desktop/meeting_minutes.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--writer",
                    "/home/user/Desktop/meeting_minutes.txt"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我在纪要里加上决议",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "在文档的最末尾另起一行，加上\"议题一决议：同意方案A\"，然后保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "cat /home/user/Desktop/meeting_minutes.txt"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "决议：同意方案A"
                ],
                "exclude": []
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}