{
    "id": "interactive_writer_ambiguous_001",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "ambiguous_instruction",
    "scenario_description": "用户想在工作报告末尾加上之前讨论过的收尾内容，但没有说明具体是什么（帮我把之前说好的东西加到文档末尾）。Agent 无从得知之前说好的东西是什么，必须主动询问用户。用户回答：在末尾加上撰写人：张三和审核人：李四两行，改完保存。",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "printf '公司工作报告\\n\\n一、工作概述\\n\\n本年度公司整体运营平稳，各项业务指标均达到预期目标。\\n\\n二、主要成果\\n\\n1. 销售额同比增长15%%\\n2. 客户满意度提升至92%%\\n3. 新增合作伙伴20家\\n\\n三、未来计划\\n\\n继续推进数字化转型，加强团队建设。\\n' > /home/user/Desktop/work_report.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--writer",
                    "/home/user/Desktop/work_report.txt"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我把之前说好的那些东西加到文档末尾",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "在文档的最末尾另起两行，分别加上「撰写人：张三」和「审核人：李四」，改完保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "cat /home/user/Desktop/work_report.txt"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "撰写人：张三",
                    "审核人：李四"
                ],
                "exclude": []
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}
