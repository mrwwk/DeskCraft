{
    "id": "interactive_writer_010",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "ambiguous_scope",
    "scenario_description": "用户要给员工记录补充部门，但未说是哪条记录。Agent 询问后只改第一条。",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "printf '员工信息表\n\n员工编号：E001\n姓名：王建国\n职位：高级工程师\n入职日期：2020年3月1日\n\n员工编号：E002\n姓名：李晓梅\n职位：产品经理\n入职日期：2021年6月15日\n\n员工编号：E003\n姓名：张浩宇\n职位：UI设计师\n入职日期：2022年9月10日\n' > /home/user/Desktop/employee_list.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 gsettings set org.gnome.desktop.screensaver idle-activation-enabled false 2>/dev/null; DISPLAY=:1 gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null; DISPLAY=:1 xset s off 2>/dev/null; DISPLAY=:1 xset -dpms 2>/dev/null; true"
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "libreoffice",
                    "--norestore",
                    "--nologo",
                    "--writer",
                    "/home/user/Desktop/employee_list.txt"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 12
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "DISPLAY=:1 xdotool key Escape 2>/dev/null; sleep 0.3; DISPLAY=:1 xdotool search --class 'soffice' windowfocus windowraise 2>/dev/null || DISPLAY=:1 wmctrl -xa 'soffice.Soffice' 2>/dev/null || true"
                ]
            }
        },
        {
            "type": "sleep",
            "parameters": {
                "seconds": 3
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我把部门信息补充进去",
            "trigger": {
                "type": "step_count",
                "value": 3
            }
        },
        {
            "phase_id": 2,
            "instruction": "在文档的最末尾另起一行，加上\"E001所属部门：技术部\"，然后保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "cat /home/user/Desktop/employee_list.txt"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "所属部门：技术部"
                ],
                "exclude": []
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}