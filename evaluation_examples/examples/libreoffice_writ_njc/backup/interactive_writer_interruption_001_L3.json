{
  "id": "interactive_writer_interruption_001",
  "snapshot": "libreoffice_writer",
  "interactive": true,
  "scenario_type": "task_interruption",
  "scenario_description": "The user interrupts the main document task for a side request, then returns to continue the original editing task.",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_english"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "bash",
          "-c",
          "echo 'This is a -ReportDraft. \\n\\nChapter 1 Overview\\n\\nOverview content goes here. ' > /home/user/Desktop/annual_report.txt"
        ]
      }
    },
    {
      "type": "execute",
      "parameters": {
        "command": [
          "bash",
          "-c",
          "libreoffice --writer /home/user/Desktop/annual_report.txt &"
        ]
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "Help me document's title\"Overview\"change \"Project overview\"",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "Wait, first Help me check how much disk space is left, openusing df -h",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "OK, , go back to that document, Help me in \"Project overview\"belowone row write \"This report summarizes key 2025 progress\", Then save the file",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "libreoffice_writer",
    "os"
  ],
  "evaluator": {
    "func": "check_include_exclude",
    "result": {
      "type": "vm_command_line",
      "command": "cat /home/user/Desktop/annual_report.txt"
    },
    "expected": {
      "type": "rule",
      "rules": {
        "include": [
          "ProjectOverview",
          "2025"
        ],
        "exclude": []
      }
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3"
}