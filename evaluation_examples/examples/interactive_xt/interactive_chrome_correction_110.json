{
  "id": "interactive_chrome_correction_110",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "correction",
  "scenario_description": "用户最初让 Agent 收藏报销政策，但随后纠正自己真正想保留的是差旅和远程办公政策，要求 Agent 修正书签栏并停留在最终目标页面。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_policy_center_110'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Policy Center</h1><ul><li><a href=\"expense_policy.html\">Expense Policy</a></li><li><a href=\"travel_policy.html\">Travel Policy</a></li><li><a href=\"remote_work_policy.html\">Remote Work Policy</a></li></ul></body></html>', encoding='utf-8'); (d/'expense_policy.html').write_text('<html><body><h1>Expense Policy</h1><p>Submit expenses within 10 days.</p></body></html>', encoding='utf-8'); (d/'travel_policy.html').write_text('<html><body><h1>Travel Policy</h1><p>Book flights through the approved portal.</p></body></html>', encoding='utf-8'); (d/'remote_work_policy.html').write_text('<html><body><h1>Remote Work Policy</h1><p>Remote days require manager approval.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_policy_center_110/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先打开 Expense Policy，并把它加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我刚说错了，不是报销政策。请把 Expense Policy 的书签去掉，改成把 Travel Policy 加到书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "另外再把 Remote Work Policy 也加入书签栏，并最后停留在 Remote Work Policy 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_policy_center_110/remote_work_policy.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_policy_center_110/travel_policy.html",
            "file:///home/user/Desktop/chrome_policy_center_110/remote_work_policy.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
