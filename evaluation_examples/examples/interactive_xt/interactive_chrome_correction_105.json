{
  "id": "interactive_chrome_correction_105",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "correction",
  "scenario_description": "用户一开始让 Agent 打开并收藏一个总览页，随后纠正说真正需要的是认证文档页。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_api_docs_105'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>API Docs</h1><ul><li><a href=\"api_overview.html\">API Overview</a></li><li><a href=\"api_authentication.html\">API Authentication</a></li></ul></body></html>', encoding='utf-8'); (d/'api_overview.html').write_text('<html><body><h1>API Overview</h1><p>General API concepts.</p></body></html>', encoding='utf-8'); (d/'api_authentication.html').write_text('<html><body><h1>API Authentication</h1><p>Authentication details.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_api_docs_105/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "打开 API Overview 页面，并把它加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "不对，我真正要的是 API Authentication 这一页；把书签改成它，最后也停留在那一页。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_api_docs_105/api_authentication.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_api_docs_105/api_authentication.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
