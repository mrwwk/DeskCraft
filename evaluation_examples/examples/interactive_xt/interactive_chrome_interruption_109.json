{
  "id": "interactive_chrome_interruption_109",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "interruption",
  "scenario_description": "用户一开始想保留活动场地信息，但浏览过程中被打断，临时改成更关注停车信息，并要求移除原本的书签选择。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_event_planner_109'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Event Planner</h1><ul><li><a href=\"venue.html\">Venue</a></li><li><a href=\"agenda.html\">Agenda</a></li><li><a href=\"parking.html\">Parking Information</a></li></ul></body></html>', encoding='utf-8'); (d/'venue.html').write_text('<html><body><h1>Venue</h1><p>Main hall opens at 8:00.</p></body></html>', encoding='utf-8'); (d/'agenda.html').write_text('<html><body><h1>Agenda</h1><p>Keynote starts at 9:00.</p></body></html>', encoding='utf-8'); (d/'parking.html').write_text('<html><body><h1>Parking Information</h1><p>Lot C is the visitor lot.</p></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_event_planner_109/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先打开 Venue 页面并把它加入书签栏。",
      "trigger": {
        "type": "step_count",
        "value": 2
      }
    },
    {
      "phase_id": 2,
      "instruction": "先停一下，我现在更关心停车信息。请把 Venue 的书签删掉，改成打开 Parking Information 并加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "再把 Agenda 打开看一眼，但最后回到 Parking Information 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_event_planner_109/parking.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_event_planner_109/parking.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
