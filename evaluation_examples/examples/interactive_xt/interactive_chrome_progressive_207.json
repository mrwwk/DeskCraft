{
  "id": "interactive_chrome_progressive_207",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "progressive_refinement",
  "scenario_description": "用户逐步搭建自己的 UI 参考阅读栈：先看 token，再加 chart 和 dialog 模式，最后补一个移动导航参考并筛掉不必要页面。",
  "source": "https://www.frontendmentor.io/challenges/time-tracking-dashboard-UIQ7167Jw | https://www.frontendmentor.io/challenges/social-media-dashboard-with-theme-switcher-6oY8ozp_H | https://developer.mozilla.org/en-US/docs/Web/HTML/Element/dialog | authors",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/design_review_stack_207'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Design Review Stack</h1><ul><li><a href=\"tokens.html\">Tokens</a></li><li><a href=\"chart_board.html\">Chart Board</a></li><li><a href=\"dialog_pattern.html\">Dialog Pattern</a></li><li><a href=\"mobile_nav.html\">Mobile Nav</a></li></ul></body></html>', encoding='utf-8'); (d/'tokens.html').write_text('<html><body><h1>Tokens</h1></body></html>', encoding='utf-8'); (d/'chart_board.html').write_text('<html><body><h1>Chart Board</h1></body></html>', encoding='utf-8'); (d/'dialog_pattern.html').write_text('<html><body><h1>Dialog Pattern</h1></body></html>', encoding='utf-8'); (d/'mobile_nav.html').write_text('<html><body><h1>Mobile Nav</h1></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/design_review_stack_207/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先把 Tokens 页面打开成单独标签页。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "再把 Chart Board 和 Dialog Pattern 都打开出来，并把 Chart Board 加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后把 Mobile Nav 也打开出来，只保留 Chart Board、Dialog Pattern、Mobile Nav 这 3 个参考标签，不要留首页和 Tokens 标签；把 Mobile Nav 也加入书签栏，并停留在 Mobile Nav。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_tabs",
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "open_tabs_info"
      },
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "urls": [
            "file:///home/user/Desktop/design_review_stack_207/chart_board.html",
            "file:///home/user/Desktop/design_review_stack_207/dialog_pattern.html",
            "file:///home/user/Desktop/design_review_stack_207/mobile_nav.html"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/design_review_stack_207/mobile_nav.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/design_review_stack_207/chart_board.html",
            "file:///home/user/Desktop/design_review_stack_207/mobile_nav.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
