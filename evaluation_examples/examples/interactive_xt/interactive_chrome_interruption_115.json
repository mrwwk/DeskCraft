{
  "id": "interactive_chrome_interruption_115",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "interruption",
  "scenario_description": "用户一开始想先留住某个供应商指南页面，但浏览到一半突然意识到真正要留的是另外两份结算与安全文档，要求 Agent 中断原计划重新整理标签与书签。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/chrome_vendor_docs_115'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>Vendor Docs</h1><ul><li><a href=\"vendor_guide.html\">Vendor Guide</a></li><li><a href=\"security_checklist.html\">Security Checklist</a></li><li><a href=\"invoice_rules.html\">Invoice Rules</a></li></ul></body></html>', encoding='utf-8'); (d/'vendor_guide.html').write_text('<html><body><h1>Vendor Guide</h1></body></html>', encoding='utf-8'); (d/'security_checklist.html').write_text('<html><body><h1>Security Checklist</h1></body></html>', encoding='utf-8'); (d/'invoice_rules.html').write_text('<html><body><h1>Invoice Rules</h1></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/chrome_vendor_docs_115/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先打开 Vendor Guide 并把它加入书签栏。",
      "trigger": {
        "type": "step_count",
        "value": 2
      }
    },
    {
      "phase_id": 2,
      "instruction": "等一下，Vendor Guide 先不用留。把 Security Checklist 和 Invoice Rules 都打开，只保留这两条书签到书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后只保留 Security Checklist 和 Invoice Rules 这两个文档标签，并停留在 Invoice Rules 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_tabs",
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "open_tabs_info"
      },
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "urls": [
            "file:///home/user/Desktop/chrome_vendor_docs_115/security_checklist.html",
            "file:///home/user/Desktop/chrome_vendor_docs_115/invoice_rules.html"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/chrome_vendor_docs_115/invoice_rules.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/chrome_vendor_docs_115/security_checklist.html",
            "file:///home/user/Desktop/chrome_vendor_docs_115/invoice_rules.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
