{
  "id": "aa8fb8bf-6f67-44e0-b51b-93a116afc899",
  "task_slug": "profile_yaml_update_from_local_brief",
  "difficulty": "L1",
  "snapshot": "multi_apps",
  "instruction": "The personal site config in ~/Desktop/site_profile/_config.yml is outdated. Open the local brief file PROFILE_BRIEF.txt in Chrome so you can read the new profile details, then use VS Code to update _config.yml with the new name, email, and role from the brief. Before editing, create a backup named _config.yml.bak in the same folder.",
  "source": [
    "https://docs.github.com/en/pages",
    "现实场景构造来源：个人站点换人维护时，根据本地 profile brief 更新 Jekyll/YAML 资料并保留备份的常见 handoff 流程"
  ],
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": "python3 - <<'PY'\nfrom pathlib import Path\nbase = Path('/home/user/Desktop/site_profile')\nbase.mkdir(parents=True, exist_ok=True)\n(base / 'PROFILE_BRIEF.txt').write_text('name=Lin Zhao\\nemail=lin.zhao@example.com\\nrole=Research Engineer\\n')\n(base / '_config.yml').write_text(\"\"\"name: Old Name\nauthor:\n  name: Old Name\n  email: old@example.com\nrole: Intern\n\"\"\")\nPY",
        "shell": true
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["google-chrome", "--remote-debugging-port=1337"]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["socat", "tcp-listen:9222,fork", "tcp:localhost:1337"]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/site_profile/PROFILE_BRIEF.txt"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["code", "/home/user/Desktop/site_profile"]
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": ["chrome", "vscode", "os"],
  "evaluator": {
    "func": ["is_expected_active_tab_approximate", "check_json", "check_include_exclude"],
    "result": [
      {
        "type": "active_tab_info"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/site_profile/_config.yml",
        "dest": "_config.yml"
      },
      {
        "type": "vm_command_line",
        "command": "ls /home/user/Desktop/site_profile/",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/site_profile/PROFILE_BRIEF.txt"
        }
      },
      {
        "type": "rule",
        "rules": {
          "expect": [
            {"key": ["name"], "method": "eq", "ref": "Lin Zhao"},
            {"key": ["author", "name"], "method": "eq", "ref": "Lin Zhao"},
            {"key": ["author", "email"], "method": "eq", "ref": "lin.zhao@example.com"},
            {"key": ["role"], "method": "eq", "ref": "Research Engineer"}
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": ["_config.yml.bak"],
          "exclude": []
        }
      }
    ],
    "options": [null, {"is_yaml": true}, null],
    "conj": "and"
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
