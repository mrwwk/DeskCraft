{
  "id": "26124979-e7ed-4e87-80b7-dd2fe745d88f",
  "task_slug": "spec_json_vscode_project_dir_setup",
  "difficulty": "L1",
  "snapshot": "os",
  "instruction": "A project specification file is waiting at ~/Desktop/project_spec.json. Read the file to discover the required editor settings and project structure. Apply tabSize and wordWrap to VS Code User Settings exactly as specified in the JSON. Then use the terminal to create the log directory and empty log file whose path is listed under 'logPath' in that same spec.",
  "source": "authors",
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": "python3 -c \"import json; json.dump({'tabSize': 2, 'wordWrap': 'on', 'projectName': 'mywebapp', 'logPath': '/home/user/Desktop/logs/app.log'}, open('/home/user/Desktop/project_spec.json', 'w'), indent=2)\"",
        "shell": true
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["code"]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": ["os", "vscode"],
  "evaluator": {
    "func": ["check_json_settings", "check_include_exclude"],
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/.config/Code/User/settings.json",
        "dest": "settings.json"
      },
      {
        "type": "vm_command_line",
        "command": "ls /home/user/Desktop/logs/",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "expected": {
            "editor.tabSize": 2,
            "editor.wordWrap": "on"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": ["app.log"],
          "exclude": []
        }
      }
    ],
    "conj": "and"
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
