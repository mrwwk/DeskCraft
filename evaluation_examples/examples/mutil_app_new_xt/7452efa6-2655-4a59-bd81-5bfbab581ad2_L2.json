{
  "id": "7452efa6-2655-4a59-bd81-5bfbab581ad2",
  "task_slug": "devnotes_parse_vscode_rulers_chrome_docs",
  "difficulty": "L2",
  "snapshot": "os",
  "instruction": "The team's development notes are at ~/Desktop/DEVNOTES.md. Read this file carefully — it specifies three editor settings and a reference documentation URL. Apply every specified setting to VS Code User Settings: set editor.tabSize to the tabSize value in the notes, set editor.wordWrapColumn to the wrapColumn value, and set editor.rulers to a single-element array containing the rulerAt value. Then extract the docsUrl from the notes and open it in a Chrome tab. Finally mark the notes as processed by creating ~/Desktop/DEVNOTES.applied with the single line 'applied'.",
  "source": [
    "https://code.visualstudio.com/docs/editor/codebasics",
    "https://code.visualstudio.com/docs/getstarted/settings",
    "现实场景构造来源：团队把 tab size、wrap column、ruler 和文档链接写进 DEVNOTES，要求成员解析后同步到 VS Code 的常见规范下发流程"
  ],
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": "printf '# Editor Settings\\ntabSize: 4\\nwrapColumn: 88\\nrulerAt: 88\\ndocsUrl: https://code.visualstudio.com/docs/editor/codebasics\\n' > /home/user/Desktop/DEVNOTES.md",
        "shell": true
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["google-chrome", "--remote-debugging-port=1337"]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["socat", "tcp-listen:9222,fork", "tcp:localhost:1337"]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": ["code"]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": ["os", "vscode", "chrome"],
  "evaluator": {
    "func": ["check_json_settings", "is_expected_active_tab_approximate", "check_include_exclude"],
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/.config/Code/User/settings.json",
        "dest": "settings.json"
      },
      {
        "type": "active_tab_info"
      },
      {
        "type": "vm_command_line",
        "command": "cat /home/user/Desktop/DEVNOTES.applied",
        "shell": true
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "expected": {
            "editor.tabSize": 4,
            "editor.wordWrapColumn": 88,
            "editor.rulers": [88]
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "https://code.visualstudio.com/docs/editor/codebasics"
        }
      },
      {
        "type": "rule",
        "rules": {
          "include": ["applied"],
          "exclude": []
        }
      }
    ],
    "conj": "and"
  },
  "proxy": true,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
