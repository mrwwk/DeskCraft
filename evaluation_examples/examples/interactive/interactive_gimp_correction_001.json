{
    "id": "interactive_gimp_correction_001",
    "snapshot": "gimp",
    "interactive": true,
    "scenario_type": "error_correction",
    "scenario_description": "用户要求旋转图片，但发现方向不对，需要纠正后再添加边框",
    "user_persona": {
        "expertise_level": "intermediate",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "download",
            "parameters": {
                "files": [
                    {
                        "url": "https://huggingface.co/datasets/xlangai/ubuntu_osworld_file_cache/resolve/main/gimp/045bf3ff-9077-4b86-b483-a1040a949cff/gate.jpeg",
                        "path": "/home/user/Desktop/photo.png"
                    }
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "gimp",
                    "/home/user/Desktop/photo.png"
                ]
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我把这张照片顺时针旋转90度",
            "trigger": {
                "type": "agent_done"
            }
        },
        {
            "phase_id": 2,
            "instruction": "不对不对，我要的是逆时针旋转90度，你帮我撤销刚才的操作然后重新转一下",
            "trigger": {
                "type": "agent_done"
            }
        },
        {
            "phase_id": 3,
            "instruction": "好的，现在帮我给图片加一个5像素宽的黑色边框，然后导出保存为 corrected_photo.png",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "gimp"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "python -c \"import cv2; import sys; img = cv2.imread('/home/user/Desktop/corrected_photo.png'); sys.exit(0) if (img is not None and tuple(img[0,0]) == (0,0,0)) else sys.exit(1)\" && echo 'PASSED' || echo 'FAILED'"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "PASSED"
                ],
                "exclude": [
                    "FAILED"
                ]
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}