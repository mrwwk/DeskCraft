{
    "id": "interactive_gimp_ambiguous_001",
    "snapshot": "gimp",
    "interactive": true,
    "scenario_type": "ambiguous_instruction",
    "scenario_description": "用户给出模糊的图片编辑指令（随便修一下），期望 Agent 主动询问具体编辑需求后再操作",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "download",
            "parameters": {
                "files": [
                    {
                        "url": "https://huggingface.co/datasets/xlangai/ubuntu_osworld_file_cache/resolve/main/gimp/d16c99dc-2a1e-46f2-b350-d97c86c85c15/dog_with_background.png",
                        "path": "/home/user/Desktop/photo_to_edit.png"
                    }
                ]
            }
        },
        {
            "type": "launch",
            "parameters": {
                "command": [
                    "gimp",
                    "/home/user/Desktop/photo_to_edit.png"
                ]
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我修一下这张照片，感觉不太好看",
            "trigger": {
                "type": "agent_asks"
            }
        },
        {
            "phase_id": 2,
            "instruction": "帮我把图片缩小到 640x480 大小，然后再水平翻转一下",
            "trigger": {
                "type": "agent_done"
            }
        },
        {
            "phase_id": 3,
            "instruction": "好的，最后帮我导出保存到桌面，文件名叫 edited_photo.png",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "gimp"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "python3 -c \"from PIL import Image; img = Image.open('/home/user/Desktop/edited_photo.png'); w, h = img.size; print(f'SIZE:{w}x{h}'); print('PASSED' if w == 640 and h == 480 else 'FAILED')\" 2>/dev/null || echo 'FAILED'"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "SIZE:640x480",
                    "PASSED"
                ],
                "exclude": [
                    "FAILED"
                ]
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}