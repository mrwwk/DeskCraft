{
    "id": "interactive_os_stepcount_001",
    "snapshot": "os",
    "interactive": true,
    "scenario_type": "interruption",
    "scenario_description": "用户要求Agent创建多个文件夹，但在Agent执行几步后，用户突然改变主意要求按另一种方式创建",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "rm -rf /home/user/Desktop/projects"
                ]
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我在桌面上建一个叫 projects 的文件夹，然后在里面建 5 个叫 project1 到 project5 的子文件夹",
            "trigger": {
                "type": "step_count",
                "value": 2
            }
        },
        {
            "phase_id": 2,
            "instruction": "等一下，我改主意了，project 文件夹里面不要建 project1 到 5 了，改成建两个文件夹：frontend 和 backend",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "os"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "ls /home/user/Desktop/projects/ 2>/dev/null | sort | tr '\\n' ' '"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "backend",
                    "frontend"
                ],
                "exclude": [
                    "project1",
                    "project2",
                    "project3",
                    "project4",
                    "project5"
                ]
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "high"
}