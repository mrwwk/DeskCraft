{
    "id": "interactive_writer_interruption_001",
    "snapshot": "libreoffice_writer",
    "interactive": true,
    "scenario_type": "task_interruption",
    "scenario_description": "用户在编辑文档过程中临时让 Agent 去做另一件事（查看磁盘空间），然后回来继续原来的文档编辑任务",
    "user_persona": {
        "expertise_level": "intermediate",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "echo '这是一份年度报告的草稿。\\n\\n第一章 概述\\n\\n这里是概述内容。' > /home/user/Desktop/annual_report.txt"
                ]
            }
        },
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "libreoffice --writer /home/user/Desktop/annual_report.txt &"
                ]
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "帮我把这个文档的标题\"概述\"改成\"项目概述\"",
            "trigger": {
                "type": "agent_done"
            }
        },
        {
            "phase_id": 2,
            "instruction": "等一下，先帮我看看系统磁盘空间还剩多少，打开终端用 df -h 看一下",
            "trigger": {
                "type": "agent_done"
            }
        },
        {
            "phase_id": 3,
            "instruction": "好的知道了，回到刚才那个文档，帮我在\"项目概述\"下面加一行写\"本报告总结了2025年度的关键进展\"，然后保存文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "libreoffice_writer",
        "os"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "cat /home/user/Desktop/annual_report.txt"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "项目概述",
                    "2025"
                ],
                "exclude": []
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "low"
}