{
    "id": "interactive_os_ambiguous_001",
    "snapshot": "os",
    "interactive": true,
    "scenario_type": "ambiguous_instruction",
    "scenario_description": "用户给出模糊的桌面整理指令，期望 Agent 主动询问细节后再执行",
    "user_persona": {
        "expertise_level": "beginner",
        "communication_style": "casual_chinese"
    },
    "config": [
        {
            "type": "execute",
            "parameters": {
                "command": [
                    "bash",
                    "-c",
                    "touch /home/user/Desktop/photo1.png /home/user/Desktop/photo2.jpg /home/user/Desktop/notes.txt /home/user/Desktop/report.pdf /home/user/Desktop/video.mp4; mkdir -p /home/user/Pictures /home/user/Documents /home/user/Videos"
                ]
            }
        }
    ],
    "phases": [
        {
            "phase_id": 1,
            "instruction": "我桌面东西太多了，帮我整理一下吧",
            "trigger": {
                "type": "agent_asks"
            }
        },
        {
            "phase_id": 2,
            "instruction": "把图片文件都移到 Pictures 文件夹，文档移到 Documents 文件夹，视频移到 Videos 文件夹",
            "trigger": {
                "type": "agent_done"
            }
        },
        {
            "phase_id": 3,
            "instruction": "好的，帮我确认一下桌面上还剩什么文件",
            "trigger": {
                "type": "agent_done"
            }
        }
    ],
    "trajectory": "trajectories/",
    "related_apps": [
        "os"
    ],
    "evaluator": {
        "func": "check_include_exclude",
        "result": {
            "type": "vm_command_line",
            "command": "echo PIC:$(ls /home/user/Pictures/ 2>/dev/null | sort | tr '\\n' ' ') DOC:$(ls /home/user/Documents/ 2>/dev/null | sort | tr '\\n' ' ') VID:$(ls /home/user/Videos/ 2>/dev/null | sort | tr '\\n' ' ')"
        },
        "expected": {
            "type": "rule",
            "rules": {
                "include": [
                    "photo1.png",
                    "photo2.jpg",
                    "notes.txt",
                    "report.pdf",
                    "video.mp4"
                ],
                "exclude": [
                    "PIC:notes.txt",
                    "PIC:report.pdf",
                    "PIC:video.mp4",
                    "DOC:photo1.png",
                    "DOC:video.mp4",
                    "VID:photo1.png",
                    "VID:notes.txt"
                ]
            }
        }
    },
    "proxy": false,
    "fixed_ip": false,
    "possibility_of_env_change": "high"
}