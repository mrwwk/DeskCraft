{
  "id": "f79439ad-3ee8-4f99-a518-0eb60e5652b0",
  "task_slug": "ryanair_family_flight_search",
  "difficulty": "L3",
  "snapshot": "chrome",
  "instruction": "On Ryanair, search a one-way flight from Dublin (DUB) to Vienna (VIE) on the 10th of next month for 2 adults and 1 teen (no children).",
  "source": "test_task_2_harder",
  "config": [
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "https://www.ryanair.com/gb/en"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": "check_direct_json_object",
    "result": {
      "type": "active_tab_url_parse",
      "goto_prefix": "https://www.",
      "parse_keys": [
        "originIata",
        "destinationIata",
        "tpAdults",
        "tpTeens",
        "tpChildren",
        "tpStartDate",
        "isReturn"
      ],
      "replace": {
        "tpStartDate": "time"
      }
    },
    "expected": {
      "type": "rule_relativeTime",
      "rules": {
        "relativeTime": {
          "from": "10th next month"
        },
        "expected": {
          "originIata": "DUB",
          "destinationIata": "VIE",
          "tpAdults": "2",
          "tpTeens": "1",
          "tpChildren": "0",
          "time": "{Year}-{Month0D}-{DayD}",
          "isReturn": "false"
        }
      }
    }
  },
  "proxy": true,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
