{
  "id": "interactive_vscode_requirement_change_202",
  "snapshot": "vscode",
  "interactive": true,
  "scenario_type": "requirement_change",
  "scenario_description": "用户先让 Agent 做一个常规的定价页，随后改变套餐命名和主推方案要求，要求 Agent 在已有 UI 原型上继续重构。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "/bin/bash",
          "-c",
          "rm -rf /home/user/Desktop/ui_pricing_studio_202 && mkdir -p /home/user/Desktop/ui_pricing_studio_202"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/ui_pricing_studio_202"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先做一个 pricing 页面：创建 index.html、styles.css 和 manifest.json，页面标题是 Pricing Plans，里面有 id=\"pricing-grid\" 的容器和 3 个 class=\"pricing-card\" 的卡片，计划名先写 Starter、Growth、Scale。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我改一下需求：第三个计划不要叫 Scale，改成 Enterprise；第二个计划要加 class=\"popular\"，而且卡片里要有可见文本 Popular。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后把 Enterprise 卡片的按钮文案改成 Talk to Sales，并在 manifest.json 里写 project=pricing-studio, theme=violet, version=2.0。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "vscode"
  ],
  "evaluator": {
    "postconfig": [
      {
        "type": "activate_window",
        "parameters": {
          "window_name": "Visual Studio Code"
        }
      },
      {
        "type": "sleep",
        "parameters": {
          "seconds": 0.5
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "python",
            "-c",
            "import pyautogui, time; pyautogui.hotkey('ctrl', 's'); time.sleep(0.5)"
          ]
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "/bin/bash",
            "-c",
            "cd /home/user/Desktop/ui_pricing_studio_202 && zip -qr /home/user/Desktop/ui_pricing_studio_202_bundle.zip index.html styles.css manifest.json"
          ]
        }
      }
    ],
    "func": [
      "check_ui_bundle_required_files",
      "check_ui_bundle_required_keywords",
      "check_ui_bundle_manifest_subset",
      "check_ui_bundle_html_checks"
    ],
    "conj": "and",
    "expected": [
      {
        "type": "rule",
        "rules": {
          "required_files": [
            "index.html",
            "styles.css",
            "manifest.json"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "required_file_keywords": {
            "index.html": [
              "Pricing Plans",
              "id=\"pricing-grid\"",
              "pricing-card",
              "Starter",
              "Growth",
              "Enterprise",
              "Popular",
              "Talk to Sales"
            ],
            "styles.css": [
              "#pricing-grid",
              ".pricing-card",
              ".popular"
            ],
            "manifest.json": [
              "pricing-studio",
              "violet",
              "2.0"
            ]
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected_manifest": {
            "project": "pricing-studio",
            "theme": "violet",
            "version": "2.0"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "html_checks": {
            "index.html": [
              { "type": "selector_exists", "selector": "#pricing-grid" },
              { "type": "selector_count", "selector": ".pricing-card", "count": 3 },
              { "type": "selector_exists", "selector": ".pricing-card.popular" },
              { "type": "text_present", "text": "Popular" },
              { "type": "text_present", "text": "Talk to Sales" }
            ]
          }
        }
      }
    ],
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_pricing_studio_202_bundle.zip",
        "dest": "ui_pricing_studio_202_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_pricing_studio_202_bundle.zip",
        "dest": "ui_pricing_studio_202_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_pricing_studio_202_bundle.zip",
        "dest": "ui_pricing_studio_202_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_pricing_studio_202_bundle.zip",
        "dest": "ui_pricing_studio_202_bundle.zip"
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
