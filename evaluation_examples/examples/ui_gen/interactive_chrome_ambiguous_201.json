{
  "id": "interactive_chrome_ambiguous_201",
  "snapshot": "chrome",
  "interactive": true,
  "scenario_type": "ambiguous_instruction",
  "scenario_description": "用户在本地设计参考站里只模糊地说想留好后面做 UI 时要看的页面，期望 Agent 先确认具体要保留哪些参考页，再整理书签和当前标签。",
  "source": "https://www.frontendmentor.io/challenges | authors",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/ui_ref_hub_201'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<html><body><h1>UI Reference Hub</h1><ul><li><a href=\"color_system.html\">Color System</a></li><li><a href=\"component_gallery.html\">Component Gallery</a></li><li><a href=\"copy_tips.html\">Copy Tips</a></li></ul></body></html>', encoding='utf-8'); (d/'color_system.html').write_text('<html><body><h1>Color System</h1></body></html>', encoding='utf-8'); (d/'component_gallery.html').write_text('<html><body><h1>Component Gallery</h1></body></html>', encoding='utf-8'); (d/'copy_tips.html').write_text('<html><body><h1>Copy Tips</h1></body></html>', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "google-chrome",
          "--remote-debugging-port=1337"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "socat",
          "tcp-listen:9222,fork",
          "tcp:localhost:1337"
        ]
      }
    },
    {
      "type": "chrome_open_tabs",
      "parameters": {
        "urls_to_open": [
          "file:///home/user/Desktop/ui_ref_hub_201/index.html"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Google Chrome"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "这个本地参考站里有几页我做界面时会常看，帮我先留好。",
      "trigger": {
        "type": "agent_asks"
      }
    },
    {
      "phase_id": 2,
      "instruction": "把 Color System 和 Component Gallery 这两页都打开并加入书签栏。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后停留在 Component Gallery 页面。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "chrome"
  ],
  "evaluator": {
    "func": [
      "is_expected_active_tab",
      "is_expected_bookmarks"
    ],
    "conj": "and",
    "result": [
      {
        "type": "active_url_from_accessTree"
      },
      {
        "type": "bookmarks"
      }
    ],
    "expected": [
      {
        "type": "rule",
        "rules": {
          "type": "url",
          "url": "file:///home/user/Desktop/ui_ref_hub_201/component_gallery.html"
        }
      },
      {
        "type": "rule",
        "rules": {
          "type": "bookmark_bar_websites_urls",
          "urls": [
            "file:///home/user/Desktop/ui_ref_hub_201/color_system.html",
            "file:///home/user/Desktop/ui_ref_hub_201/component_gallery.html"
          ]
        }
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
