{
  "id": "5e8b3c4f-2d54-4f8a-8a7d-3c1f9b6e2a75",
  "snapshot": "vscode",
  "instruction": "Create a pricing page project in VS Code at /home/user/Desktop/pricing_table_page. Create index.html and styles.css. The page should contain the title \"Pricing Plans\" and exactly three pricing cards inside a container with id=\"pricing-grid\". Each pricing card must use class=\"pricing-card\". The plan names must be Starter, Pro, and Enterprise. Each card should include a price and a short feature list. One card must be visually marked as Popular by including class=\"popular\" on that pricing card and visible text \"Popular\" in the card. Save both files.",
  "source": "",
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "/bin/bash",
          "-c",
          "mkdir -p /home/user/Desktop/pricing_table_page"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/pricing_table_page"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "vscode"
  ],
  "evaluator": {
    "postconfig": [
      {
        "type": "activate_window",
        "parameters": {
          "window_name": "Visual Studio Code"
        }
      },
      {
        "type": "sleep",
        "parameters": {
          "seconds": 0.5
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "python",
            "-c",
            "import pyautogui, time; pyautogui.hotkey('ctrl', 's'); time.sleep(0.5)"
          ]
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "/bin/bash",
            "-c",
            "cd /home/user/Desktop/pricing_table_page && zip -qr /home/user/Desktop/pricing_table_page_bundle.zip index.html styles.css"
          ]
        }
      }
    ],
    "func": [
      "check_ui_bundle_required_files",
      "check_ui_bundle_required_keywords",
      "check_ui_bundle_html_checks"
    ],
    "conj": "and",
    "expected": [
      {
        "type": "rule",
        "rules": {
          "required_files": [
            "index.html",
            "styles.css"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "required_file_keywords": {
            "styles.css": [
              ".pricing-card",
              ".popular",
              "border",
              "padding"
            ]
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "html_checks": {
            "index.html": [
              { "type": "text_present", "text": "Pricing Plans" },
              { "type": "selector_exists", "selector": "#pricing-grid" },
              { "type": "selector_count", "selector": ".pricing-card", "count": 3 },
              { "type": "text_present", "text": "Starter" },
              { "type": "text_present", "text": "Pro" },
              { "type": "text_present", "text": "Enterprise" },
              { "type": "selector_exists", "selector": ".pricing-card.popular" },
              { "type": "text_present", "text": "Popular" }
            ]
          }
        }
      }
    ],
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/pricing_table_page_bundle.zip",
        "dest": "pricing_table_page_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/pricing_table_page_bundle.zip",
        "dest": "pricing_table_page_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/pricing_table_page_bundle.zip",
        "dest": "pricing_table_page_bundle.zip"
      }
    ]
