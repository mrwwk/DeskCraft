  "snapshot": "vscode",
  "instruction": "Create a simple landing page project in VS Code at /home/user/Desktop/mint_hero_page. Create two files: index.html and manifest.json. In index.html, build a simple page for Mint Launch using a main container <main id=\"app\"> and a hero section <section id=\"hero\" class=\"hero\">. Inside the hero section, include a heading with the exact text \"Mint Launch\", a short descriptive paragraph, and a primary button <button id=\"cta\">Get Started</button>. In manifest.json, set project to \"mint-hero-page\", theme to \"mint\", and version to \"1.0\". Save both files.",
  "source": "https://www.frontendmentor.io/challenges | authors",
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "/bin/bash",
          "-c",
          "mkdir -p /home/user/Desktop/mint_hero_page"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/mint_hero_page"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "trajectory": "trajectories/",
