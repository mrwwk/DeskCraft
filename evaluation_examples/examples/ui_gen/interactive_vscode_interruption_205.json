{
  "id": "interactive_vscode_interruption_205",
  "snapshot": "vscode",
  "interactive": true,
  "scenario_type": "interruption",
  "scenario_description": "用户一开始让 Agent 做注册表单原型，但在编辑过程中突然改变方向，要求改成 waitlist 页面并丢弃最初复杂表单的结构。",
  "user_persona": {
    "expertise_level": "intermediate",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "/bin/bash",
          "-c",
          "rm -rf /home/user/Desktop/ui_waitlist_flow_205 && mkdir -p /home/user/Desktop/ui_waitlist_flow_205"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/ui_waitlist_flow_205"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先做一个 signup form 原型：创建 index.html、styles.css、script.js，页面标题是 Create Account，表单 id=\"signup-form\"，至少先放上 name、email、company 三个输入框和一个按钮。",
      "trigger": {
        "type": "step_count",
        "value": 3
      }
    },
    {
      "phase_id": 2,
      "instruction": "先停一下，不要做 Create Account 了，改成一个 waitlist 页面。最终页面要有 <main id=\"waitlist-app\">、<section id=\"hero\">、<section id=\"benefits\">、<form id=\"waitlist-form\">，只保留一个 email 输入框 id=\"email\" 和按钮 <button id=\"join-button\">Join Waitlist</button>。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "再加一个 id=\"status-message\" 的消息区域，并在 manifest.json 里写 project=waitlist-flow, theme=sunset, version=1.0。保存所有文件。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "vscode"
  ],
  "evaluator": {
    "postconfig": [
      {
        "type": "activate_window",
        "parameters": {
          "window_name": "Visual Studio Code"
        }
      },
      {
        "type": "sleep",
        "parameters": {
          "seconds": 0.5
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "python",
            "-c",
            "import pyautogui, time; pyautogui.hotkey('ctrl', 's'); time.sleep(0.5)"
          ]
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "/bin/bash",
            "-c",
            "cd /home/user/Desktop/ui_waitlist_flow_205 && zip -qr /home/user/Desktop/ui_waitlist_flow_205_bundle.zip index.html styles.css script.js manifest.json"
          ]
        }
      }
    ],
    "func": [
      "check_ui_bundle_required_files",
      "check_ui_bundle_required_keywords",
      "check_ui_bundle_manifest_subset",
      "check_ui_bundle_html_checks"
    ],
    "conj": "and",
    "expected": [
      {
        "type": "rule",
        "rules": {
          "required_files": [
            "index.html",
            "styles.css",
            "script.js",
            "manifest.json"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "required_file_keywords": {
            "index.html": [
              "id=\"waitlist-app\"",
              "id=\"hero\"",
              "id=\"benefits\"",
              "id=\"waitlist-form\"",
              "id=\"email\"",
              "id=\"join-button\"",
              "Join Waitlist",
              "id=\"status-message\""
            ],
            "styles.css": [
              "#waitlist-form",
              "#benefits"
            ],
            "script.js": [
              "join-button",
              "status-message"
            ],
            "manifest.json": [
              "waitlist-flow",
              "sunset",
              "1.0"
            ]
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected_manifest": {
            "project": "waitlist-flow",
            "theme": "sunset",
            "version": "1.0"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "html_checks": {
            "index.html": [
              { "type": "selector_exists", "selector": "main#waitlist-app" },
              { "type": "selector_exists", "selector": "form#waitlist-form" },
              { "type": "selector_exists", "selector": "#status-message" },
              { "type": "selector_count", "selector": "#waitlist-form input", "count": 1 },
              { "type": "selector_text_contains", "selector": "#join-button", "text": "Join Waitlist" }
            ]
          }
        }
      }
    ],
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_waitlist_flow_205_bundle.zip",
        "dest": "ui_waitlist_flow_205_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_waitlist_flow_205_bundle.zip",
        "dest": "ui_waitlist_flow_205_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_waitlist_flow_205_bundle.zip",
        "dest": "ui_waitlist_flow_205_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_waitlist_flow_205_bundle.zip",
        "dest": "ui_waitlist_flow_205_bundle.zip"
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
