{
  "id": "interactive_vscode_correction_204",
  "snapshot": "vscode",
  "interactive": true,
  "scenario_type": "correction",
  "scenario_description": "用户在已有 UI 启动页基础上不断纠正文案和 manifest 设定，要求 Agent 以最终纠正后的设计稿为准而不是停留在第一版。",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_chinese"
  },
  "config": [
    {
      "type": "execute",
      "parameters": {
        "command": [
          "python",
          "-c",
          "from pathlib import Path; d=Path('/home/user/Desktop/ui_badge_refresh_204'); d.mkdir(parents=True, exist_ok=True); (d/'index.html').write_text('<main id=\"app\"><section id=\"hero\"><span class=\"badge\">Starter Ready</span><h1>Launch Kit</h1><button id=\"cta\">Preview</button></section></main>', encoding='utf-8'); (d/'manifest.json').write_text('{\n  \"project\": \"launch-badge-kit\",\n  \"theme\": \"indigo\",\n  \"version\": \"1.0\"\n}\n', encoding='utf-8'); (d/'styles.css').write_text('.badge { padding: 6px 10px; }\n', encoding='utf-8')"
        ]
      }
    },
    {
      "type": "launch",
      "parameters": {
        "command": [
          "code",
          "/home/user/Desktop/ui_badge_refresh_204"
        ]
      }
    },
    {
      "type": "activate_window",
      "parameters": {
        "window_name": "Visual Studio Code"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "先把 badge 文案改成 Beta Ready，把 manifest 里的 theme 改成 indigo，version 改成 1.1。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "我纠正一下，不是 Beta Ready，应该是 Aurora Ready；theme 也不是 indigo，是 aurora；version 改成 2.0。项目名 launch-badge-kit 不要动。",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "最后把按钮文字改成 Generate UI，并保留 id=\"cta\"。保存所有修改。",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "vscode"
  ],
  "evaluator": {
    "postconfig": [
      {
        "type": "activate_window",
        "parameters": {
          "window_name": "Visual Studio Code"
        }
      },
      {
        "type": "sleep",
        "parameters": {
          "seconds": 0.5
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "python",
            "-c",
            "import pyautogui, time; pyautogui.hotkey('ctrl', 's'); time.sleep(0.5)"
          ]
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "/bin/bash",
            "-c",
            "cd /home/user/Desktop/ui_badge_refresh_204 && zip -qr /home/user/Desktop/ui_badge_refresh_204_bundle.zip index.html manifest.json styles.css"
          ]
        }
      }
    ],
    "func": [
      "check_ui_bundle_required_files",
      "check_ui_bundle_required_keywords",
      "check_ui_bundle_manifest_subset",
      "check_ui_bundle_html_checks"
    ],
    "conj": "and",
    "expected": [
      {
        "type": "rule",
        "rules": {
          "required_files": [
            "index.html",
            "manifest.json",
            "styles.css"
          ]
        }
      },
      {
        "type": "rule",
        "rules": {
          "required_file_keywords": {
            "index.html": [
              "Aurora Ready",
              "Generate UI",
              "id=\"cta\"",
              "class=\"badge\""
            ],
            "manifest.json": [
              "launch-badge-kit",
              "aurora",
              "2.0"
            ]
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "expected_manifest": {
            "project": "launch-badge-kit",
            "theme": "aurora",
            "version": "2.0"
          }
        }
      },
      {
        "type": "rule",
        "rules": {
          "html_checks": {
            "index.html": [
              { "type": "selector_exists", "selector": ".badge" },
              { "type": "selector_text_contains", "selector": ".badge", "text": "Aurora Ready" },
              { "type": "selector_text_contains", "selector": "#cta", "text": "Generate UI" }
            ]
          }
        }
      }
    ],
    "result": [
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_badge_refresh_204_bundle.zip",
        "dest": "ui_badge_refresh_204_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_badge_refresh_204_bundle.zip",
        "dest": "ui_badge_refresh_204_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_badge_refresh_204_bundle.zip",
        "dest": "ui_badge_refresh_204_bundle.zip"
      },
      {
        "type": "vm_file",
        "path": "/home/user/Desktop/ui_badge_refresh_204_bundle.zip",
        "dest": "ui_badge_refresh_204_bundle.zip"
      }
    ]
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low"
}
