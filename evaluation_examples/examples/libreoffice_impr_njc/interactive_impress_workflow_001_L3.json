{
  "id": "interactive_impress_workflow_001",
  "snapshot": "libreoffice_impress",
  "interactive": true,
  "scenario_type": "multi_step_workflow",
  "scenario_description": "Multi-step workflow: the user guides the agent through several coordinated actions or phases.",
  "user_persona": {
    "expertise_level": "beginner",
    "communication_style": "casual_english"
  },
  "config": [
    {
      "type": "download",
      "parameters": {
        "files": [
          {
            "url": "https://huggingface.co/datasets/xlangai/ubuntu_osworld_file_cache/resolve/main/libreoffice_impress/5d901039-a89c-4bfb-967b-bf66f4df075e/CPD_Background_Investigation_Process.pptx",
            "path": "/home/user/Desktop/MyPresentation.pptx"
          }
        ]
      }
    },
    {
      "type": "open",
      "parameters": {
        "path": "/home/user/Desktop/MyPresentation.pptx"
      }
    }
  ],
  "phases": [
    {
      "phase_id": 1,
      "instruction": "Please open MyPresentation.pptx on the desktop and change the title of the first slide to \"Project Report\"",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 2,
      "instruction": "Okay, now add a subtitle below the title on the first slide, writing \"Q1 2025\"",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 3,
      "instruction": "Then create a new slide and give it the title \"Project Progress\"",
      "trigger": {
        "type": "agent_done"
      }
    },
    {
      "phase_id": 4,
      "instruction": "Finally, please save the entire presentation",
      "trigger": {
        "type": "agent_done"
      }
    }
  ],
  "trajectory": "trajectories/",
  "related_apps": [
    "libreoffice_impress"
  ],
  "evaluator": {
    "postconfig": [
      {
        "type": "activate_window",
        "parameters": {
          "window_name": "MyPresentation.pptx - LibreOffice Impress",
          "strict": true
        }
      },
      {
        "type": "sleep",
        "parameters": {
          "seconds": 0.5
        }
      },
      {
        "type": "execute",
        "parameters": {
          "command": [
            "python",
            "-c",
            "import pyautogui; pyautogui.hotkey('ctrl', 's');"
          ]
        }
      },
      {
        "type": "sleep",
        "parameters": {
          "seconds": 0.5
        }
      }
    ],
    "func": "check_include_exclude",
    "result": {
      "type": "vm_command_line",
      "command": "bash -c \"unzip -p /home/user/Desktop/MyPresentation.pptx ppt/slides/slide1.xml ppt/slides/slide2.xml 2>/dev/null\""
    },
    "expected": {
      "type": "rule",
      "rules": {
        "include": [
          "Project Report",
          "Q1 2025",
          "Project Progress"
        ],
        "exclude": []
      }
    }
  },
  "proxy": false,
  "fixed_ip": false,
  "possibility_of_env_change": "low",
  "difficulty": "L3"
}